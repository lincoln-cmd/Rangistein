---
type SearchItem = {
  id: string;
  title: string;
  description: string;
  publishedAt: string;
  tags: string[];
  categoryName: string;
  categorySlug: string;
  type: string;
  featured: boolean;
};

const {
  items = [],
  placeholder = "게시물 제목, 설명, 태그, 카테고리로 검색",
  heading = "게시물 검색",
  description = "제목, 설명, 태그, 카테고리 기준으로 게시물을 빠르게 찾을 수 있습니다.",
  emptyMessage = "검색 결과가 없습니다.",
  limit = 50,
} = Astro.props;

const categoryOptions = Array.from(
  new Map(
    (items as SearchItem[]).map((item) => [
      item.categorySlug,
      {
        slug: item.categorySlug,
        name: item.categoryName,
      },
    ]),
  ).values(),
).sort((a, b) => a.name.localeCompare(b.name, "ko"));
---

<section class="search-block section-card">
  <div class="search-block__header">
    <div>
      <p class="search-block__eyebrow">Search</p>
      <h2 class="search-block__title">{heading}</h2>
      <p class="search-block__description">{description}</p>
    </div>
  </div>

  <div
    class="search-app"
    data-search-items={JSON.stringify(items)}
    data-search-limit={String(limit)}
    data-empty-message={emptyMessage}
  >
    <div class="search-controls">
      <label class="search-input-wrap">
        <span class="search-input-wrap__label">검색어</span>
        <input
          type="search"
          class="search-input"
          placeholder={placeholder}
          autocomplete="off"
        />
      </label>

      <label class="search-filter-wrap">
        <span class="search-input-wrap__label">카테고리 필터</span>
        <select class="search-select">
          <option value="">전체 카테고리</option>
          {categoryOptions.map((category) => (
            <option value={category.slug}>{category.name}</option>
          ))}
        </select>
      </label>
    </div>

    <p class="search-summary">
      검색어를 입력하면 결과가 표시됩니다.
    </p>

    <div class="search-results" hidden></div>
  </div>
</section>

<script>
  const roots = document.querySelectorAll(".search-app");

  roots.forEach((root) => {
    if (!(root instanceof HTMLElement)) return;

    const rawItems = root.dataset.searchItems;
    const rawLimit = root.dataset.searchLimit;
    const emptyMessage = root.dataset.emptyMessage || "검색 결과가 없습니다.";

    if (!rawItems) return;

    const items = JSON.parse(rawItems);
    const limit = Number(rawLimit || "50");

    const input = root.querySelector(".search-input");
    const select = root.querySelector(".search-select");
    const summary = root.querySelector(".search-summary");
    const results = root.querySelector(".search-results");

    if (!(input instanceof HTMLInputElement)) return;
    if (!(select instanceof HTMLSelectElement)) return;
    if (!(summary instanceof HTMLElement)) return;
    if (!(results instanceof HTMLElement)) return;

    const normalize = (value) => String(value ?? "").toLowerCase().trim();

    const escapeHtml = (value) =>
      String(value ?? "")
        .replaceAll("&", "&amp;")
        .replaceAll("<", "&lt;")
        .replaceAll(">", "&gt;")
        .replaceAll('"', "&quot;")
        .replaceAll("'", "&#39;");

    const escapeRegExp = (value) =>
      String(value ?? "").replace(/[.*+?^${}()|[\]\\]/g, "\\$&");

    const toTimestamp = (value) => {
      const parsed = Date.parse(String(value ?? ""));
      return Number.isNaN(parsed) ? 0 : parsed;
    };

    const newestTimestamp = Math.max(
      ...items.map((item) => toTimestamp(item.publishedAt)),
      0,
    );

    const getTypeLabel = (type) => {
      if (type === "study") return "공부 노트";
      if (type === "latest") return "최신 동향";
      return type || "기타";
    };

    const highlightText = (text, query) => {
      const safeText = escapeHtml(text);

      if (!query) return safeText;

      const escapedQuery = escapeRegExp(query.trim());

      if (!escapedQuery) return safeText;

      const regex = new RegExp(`(${escapedQuery})`, "gi");
      return safeText.replace(regex, '<mark class="search-highlight">$1</mark>');
    };

    const getRecencyBonus = (item) => {
      const publishedAt = toTimestamp(item.publishedAt);

      if (!publishedAt || !newestTimestamp) return 0;

      const diffDays = Math.max(
        0,
        (newestTimestamp - publishedAt) / (1000 * 60 * 60 * 24),
      );

      if (diffDays <= 7) return 12;
      if (diffDays <= 30) return 9;
      if (diffDays <= 90) return 6;
      if (diffDays <= 180) return 3;

      return 1;
    };

    const isRecentPost = (item) => getRecencyBonus(item) >= 9;

    const getRecommendationBonus = (item) => {
      let score = 0;

      if (item.featured) score += 30;
      if (item.type === "study") score += 4;
      if (item.type === "latest") score += 4;

      score += Math.min((item.tags || []).length, 5) * 2;
      score += getRecencyBonus(item);

      return score;
    };

    const getSearchScore = (item, query) => {
      const normalizedQuery = normalize(query);
      if (!normalizedQuery) return 0;

      const queryWords = normalizedQuery.split(/\s+/).filter(Boolean);

      const title = normalize(item.title);
      const description = normalize(item.description);
      const categoryName = normalize(item.categoryName);
      const categorySlug = normalize(item.categorySlug);
      const tags = (item.tags || []).map((tag) => normalize(tag));

      let score = 0;

      if (title === normalizedQuery) score += 120;
      if (title.includes(normalizedQuery)) score += 70;

      for (const tag of tags) {
        if (tag === normalizedQuery) score += 90;
        else if (tag.includes(normalizedQuery)) score += 55;
      }

      if (categoryName.includes(normalizedQuery)) score += 35;
      if (categorySlug.includes(normalizedQuery)) score += 25;
      if (description.includes(normalizedQuery)) score += 20;

      for (const word of queryWords) {
        if (title.includes(word)) score += 20;
        if (description.includes(word)) score += 6;
        if (categoryName.includes(word)) score += 10;
        if (categorySlug.includes(word)) score += 8;

        for (const tag of tags) {
          if (tag.includes(word)) score += 14;
        }
      }

      if (item.featured) score += 3;

      return score;
    };

    const getResultSignals = (item, query) => {
      const normalizedQuery = normalize(query);
      const title = normalize(item.title);
      const tags = (item.tags || []).map((tag) => normalize(tag));
      const signals = [];

      if (normalizedQuery) {
        if (title === normalizedQuery || title.includes(normalizedQuery)) {
          signals.push({
            label: "제목 일치",
            accent: true,
          });
        }

        if (tags.some((tag) => tag === normalizedQuery || tag.includes(normalizedQuery))) {
          signals.push({
            label: "태그 일치",
            accent: true,
          });
        }
      }

      if (item.featured) {
        signals.push({
          label: "대표 글",
          accent: false,
        });
      }

      if (isRecentPost(item)) {
        signals.push({
          label: "최신 글",
          accent: false,
        });
      }

      return signals.slice(0, 4);
    };

    const buildCard = (item, query) => {
      const anchor = document.createElement("a");
      anchor.href = `/posts/${item.id}/`;
      anchor.className = "post-card";

      const meta = document.createElement("p");
      meta.className = "post-card__meta";
      meta.textContent = `${item.categoryName} · ${item.publishedAt}`;

      const title = document.createElement("h3");
      title.className = "post-card__title";
      title.innerHTML = highlightText(item.title, query);

      const description = document.createElement("p");
      description.className = "post-card__description";
      description.innerHTML = highlightText(item.description, query);

      const badgeWrap = document.createElement("div");
      badgeWrap.className = "post-card__badges";

      const typeBadge = document.createElement("span");
      typeBadge.className = "post-card__badge";
      typeBadge.textContent = getTypeLabel(item.type);
      badgeWrap.appendChild(typeBadge);

      if (item.featured) {
        const featuredBadge = document.createElement("span");
        featuredBadge.className = "post-card__badge post-card__badge--accent";
        featuredBadge.textContent = "대표 글";
        badgeWrap.appendChild(featuredBadge);
      }

      const signalItems = getResultSignals(item, query);
      if (signalItems.length > 0) {
        const signalWrap = document.createElement("div");
        signalWrap.className = "post-card__signals";

        signalItems.forEach((signal) => {
          const span = document.createElement("span");
          span.className = signal.accent
            ? "post-card__signal post-card__signal--accent"
            : "post-card__signal";
          span.textContent = signal.label;
          signalWrap.appendChild(span);
        });

        anchor.append(meta, title, description, badgeWrap, signalWrap);
      } else {
        anchor.append(meta, title, description, badgeWrap);
      }

      const categoryHint = document.createElement("p");
      categoryHint.className = "post-card__category-hint";
      categoryHint.innerHTML = `카테고리: ${highlightText(item.categoryName, query)}`;

      const tagWrap = document.createElement("div");
      tagWrap.className = "post-card__tags";

      (item.tags || []).forEach((tag) => {
        const span = document.createElement("span");
        span.className = "post-card__tag";
        span.innerHTML = `#${highlightText(tag, query)}`;
        tagWrap.appendChild(span);
      });

      anchor.append(categoryHint, tagWrap);
      return anchor;
    };

    const buildEmpty = () => {
      const div = document.createElement("div");
      div.className = "search-empty";
      div.innerHTML = `
        <strong>검색 결과가 없습니다.</strong>
        <p>${escapeHtml(emptyMessage)}</p>
      `;
      return div;
    };

    const buildInitial = () => {
      const div = document.createElement("div");
      div.className = "search-empty";
      div.innerHTML = `
        <strong>검색 대기 중</strong>
        <p>검색어를 입력하거나 카테고리를 선택하면 결과가 표시됩니다.</p>
      `;
      return div;
    };

    const render = () => {
      const query = input.value;
      const selectedCategory = select.value;
      const normalizedQuery = normalize(query);
      const hasQuery = Boolean(normalizedQuery);
      const hasCategoryFilter = Boolean(selectedCategory);

      if (!hasQuery && !hasCategoryFilter) {
        summary.textContent = "검색어를 입력하거나 카테고리를 선택하면 결과가 표시됩니다.";
        results.innerHTML = "";
        results.hidden = false;
        results.appendChild(buildInitial());
        return;
      }

      const filtered = items
        .map((item, index) => {
          const searchScore = getSearchScore(item, query);
          const recommendationBonus = hasQuery ? getRecommendationBonus(item) : 0;

          return {
            item,
            index,
            searchScore,
            recommendationBonus,
            score: searchScore + recommendationBonus,
          };
        })
        .filter(({ item, searchScore }) => {
          const haystack = normalize(
            [
              item.title,
              item.description,
              item.categoryName,
              item.categorySlug,
              ...(item.tags || []),
            ].join(" "),
          );

          const matchesQuery = hasQuery ? haystack.includes(normalizedQuery) : true;
          const matchesCategory = hasCategoryFilter
            ? item.categorySlug === selectedCategory
            : true;

          return matchesQuery && matchesCategory && (!hasQuery || searchScore > 0);
        })
        .sort((a, b) => {
          if (hasQuery && b.score !== a.score) {
            return b.score - a.score;
          }

          if (Number(b.item.featured) !== Number(a.item.featured)) {
            return Number(b.item.featured) - Number(a.item.featured);
          }

          const dateCompare = String(b.item.publishedAt).localeCompare(
            String(a.item.publishedAt),
          );

          if (dateCompare !== 0) return dateCompare;

          return a.index - b.index;
        })
        .map(({ item }) => item);

      const visibleItems = filtered.slice(0, limit);
      const parts = [];

      if (hasQuery) {
        parts.push(`검색어 <strong>${escapeHtml(query.trim())}</strong>`);
      }

      if (hasCategoryFilter) {
        const selectedOption = select.options[select.selectedIndex];
        const label = selectedOption ? selectedOption.text : selectedCategory;
        parts.push(`카테고리 <strong>${escapeHtml(label)}</strong>`);
      }

      const conditionText = parts.length > 0 ? `${parts.join(" · ")} 기준으로 ` : "";
      const visibleSuffix =
        filtered.length > visibleItems.length
          ? ` · 상위 <strong>${visibleItems.length}</strong>개 표시`
          : "";

      summary.innerHTML = `${conditionText}검색 결과 <strong>${filtered.length}</strong>개${visibleSuffix}`;
      results.innerHTML = "";
      results.hidden = false;

      if (visibleItems.length === 0) {
        results.appendChild(buildEmpty());
        return;
      }

      visibleItems.forEach((item) => {
        results.appendChild(buildCard(item, query));
      });
    };

    input.addEventListener("input", render);
    select.addEventListener("change", render);

    render();
  });
</script>

<style>
  .section-card {
    padding: 1.5rem;
    border: 1px solid #dde5ed;
    border-radius: 20px;
    background: #ffffff;
    box-shadow: 0 10px 30px rgba(19, 36, 59, 0.06);
  }

  .search-block {
    display: grid;
    gap: 1rem;
  }

  .search-block__eyebrow {
    margin: 0 0 0.35rem;
    color: #51719a;
    font-size: 0.9rem;
    font-weight: 700;
  }

  .search-block__title {
    margin: 0 0 0.5rem;
    font-size: 1.25rem;
    font-weight: 800;
    letter-spacing: -0.02em;
  }

  .search-block__description {
    margin: 0;
    color: #58697a;
  }

  .search-app {
    display: grid;
    gap: 1rem;
  }

  .search-controls {
    display: grid;
    grid-template-columns: minmax(0, 1.6fr) minmax(220px, 0.7fr);
    gap: 0.9rem;
  }

  .search-input-wrap,
  .search-filter-wrap {
    display: grid;
    gap: 0.45rem;
  }

  .search-input-wrap__label {
    color: #35516e;
    font-size: 0.92rem;
    font-weight: 700;
  }

  .search-input,
  .search-select {
    width: 100%;
    padding: 0.9rem 1rem;
    border: 1px solid #d5e0ea;
    border-radius: 14px;
    background: #fbfdff;
    font: inherit;
  }

  .search-input:focus,
  .search-select:focus {
    outline: 2px solid rgba(40, 94, 168, 0.18);
    border-color: #8fb4de;
  }

  .search-summary {
    margin: 0;
    color: #58697a;
    font-size: 0.95rem;
  }

  .search-results {
    display: grid;
    gap: 1rem;
  }

  :global(.search-results .post-card),
  :global(.search-results .search-empty) {
    display: block;
    padding: 1rem 1.05rem;
    border: 1px solid #e4ebf2;
    border-radius: 16px;
    background: #fbfdff;
  }

  :global(.search-results .post-card) {
    transition:
      transform 0.2s ease,
      box-shadow 0.2s ease,
      border-color 0.2s ease;
  }

  :global(.search-results .post-card:hover) {
    transform: translateY(-2px);
    border-color: #bfd3ea;
    box-shadow: 0 10px 24px rgba(24, 62, 105, 0.08);
  }

  :global(.search-results .post-card__meta) {
    margin: 0 0 0.35rem;
    font-size: 0.82rem;
    font-weight: 700;
    color: #51719a;
  }

  :global(.search-results .post-card__title) {
    margin: 0 0 0.45rem;
    font-size: 1.05rem;
    line-height: 1.35;
  }

  :global(.search-results .post-card__description) {
    margin: 0;
    color: #58697a;
    font-size: 0.95rem;
    line-height: 1.65;
  }

  :global(.search-results .post-card__badges) {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 0.85rem;
  }

  :global(.search-results .post-card__badge) {
    display: inline-flex;
    align-items: center;
    padding: 0.42rem 0.72rem;
    border-radius: 999px;
    background: #eef4fb;
    color: #35516e;
    font-size: 0.8rem;
    font-weight: 700;
    line-height: 1;
  }

  :global(.search-results .post-card__badge--accent) {
    background: #dff1ff;
    color: #1f5f8b;
  }

  :global(.search-results .post-card__signals) {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 0.85rem;
  }

  :global(.search-results .post-card__signal) {
    display: inline-flex;
    align-items: center;
    padding: 0.42rem 0.72rem;
    border-radius: 999px;
    background: #eef4fb;
    color: #35516e;
    font-size: 0.8rem;
    font-weight: 700;
    line-height: 1;
  }

  :global(.search-results .post-card__signal--accent) {
    background: #fff1c2;
    color: #7c5a00;
  }

  :global(.search-results .post-card__category-hint) {
    margin: 0.8rem 0 0;
    color: #5d6d7d;
    font-size: 0.9rem;
  }

  :global(.search-results .post-card__tags) {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    margin-top: 0.85rem;
  }

  :global(.search-results .post-card__tag) {
    display: inline-flex;
    align-items: center;
    padding: 0.4rem 0.7rem;
    border-radius: 999px;
    background: #eef5fc;
    color: #244f84;
    font-size: 0.84rem;
    font-weight: 700;
  }

  :global(.search-results .search-empty) {
    color: #58697a;
  }

  :global(.search-results .search-empty strong) {
    display: block;
    margin-bottom: 0.35rem;
    color: #2e3c49;
  }

  :global(.search-results .search-empty p) {
    margin: 0;
    line-height: 1.65;
  }

  :global(.search-results .search-highlight) {
    padding: 0 0.18em;
    border-radius: 0.28em;
    background: #fff2a8;
    color: inherit;
    font-weight: 800;
  }

  @media (max-width: 820px) {
    .section-card {
      padding: 1.1rem;
      border-radius: 16px;
    }

    .search-controls {
      grid-template-columns: 1fr;
    }
  }
</style>