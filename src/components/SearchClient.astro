---
type SearchItem = {
  id: string;
  title: string;
  description: string;
  publishedAt: string;
  tags: string[];
  categoryName: string;
  categorySlug: string;
  type: string;
  featured: boolean;
};

const {
  items = [],
  placeholder = "게시물 제목, 설명, 태그, 카테고리로 검색",
  heading = "게시물 검색",
  description = "제목, 설명, 태그, 카테고리 기준으로 게시물을 빠르게 찾을 수 있습니다.",
  emptyMessage = "검색 결과가 없습니다.",
  limit = 50,
} = Astro.props;

const initialItems = items.slice(0, limit);
---

<section class="search-block section-card">
  <div class="search-block__header">
    <div>
      <p class="search-block__eyebrow">Search</p>
      <h2 class="search-block__title">{heading}</h2>
      <p class="search-block__description">{description}</p>
    </div>
  </div>

  <div
    class="search-app"
    data-search-items={JSON.stringify(items)}
    data-search-limit={String(limit)}
    data-empty-message={emptyMessage}
  >
    <label class="search-input-wrap">
      <span class="search-input-wrap__label">검색어</span>
      <input
        type="search"
        class="search-input"
        placeholder={placeholder}
        autocomplete="off"
      />
    </label>

    <p class="search-summary">
      전체 <strong>{items.length}</strong>개 게시물
    </p>

    <div class="search-results">
      {initialItems.map((item: SearchItem) => (
        <a href={`/posts/${item.id}/`} class="search-card">
          <p class="search-card__meta">
            {item.categoryName} · {item.publishedAt}
            {item.featured ? " · 대표 글" : ""}
          </p>
          <h3 class="search-card__title">{item.title}</h3>
          <p class="search-card__description">{item.description}</p>
          <div class="search-card__tags">
            {item.tags.map((tag) => (
              <span class="search-card__tag">#{tag}</span>
            ))}
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<script>
  const roots = document.querySelectorAll(".search-app");

  roots.forEach((root) => {
    if (!(root instanceof HTMLElement)) return;

    const rawItems = root.dataset.searchItems;
    const rawLimit = root.dataset.searchLimit;
    const emptyMessage = root.dataset.emptyMessage || "검색 결과가 없습니다.";

    if (!rawItems) return;

    const items = JSON.parse(rawItems);
    const limit = Number(rawLimit || "50");

    const input = root.querySelector(".search-input");
    const summary = root.querySelector(".search-summary");
    const results = root.querySelector(".search-results");

    if (!(input instanceof HTMLInputElement)) return;
    if (!(summary instanceof HTMLElement)) return;
    if (!(results instanceof HTMLElement)) return;

    const normalize = (value) => String(value ?? "").toLowerCase().trim();

    const buildCard = (item) => {
      const anchor = document.createElement("a");
      anchor.href = `/posts/${item.id}/`;
      anchor.className = "search-card";

      const meta = document.createElement("p");
      meta.className = "search-card__meta";
      meta.textContent = `${item.categoryName} · ${item.publishedAt}${item.featured ? " · 대표 글" : ""}`;

      const title = document.createElement("h3");
      title.className = "search-card__title";
      title.textContent = item.title;

      const description = document.createElement("p");
      description.className = "search-card__description";
      description.textContent = item.description;

      const tagWrap = document.createElement("div");
      tagWrap.className = "search-card__tags";

      (item.tags || []).forEach((tag) => {
        const span = document.createElement("span");
        span.className = "search-card__tag";
        span.textContent = `#${tag}`;
        tagWrap.appendChild(span);
      });

      anchor.append(meta, title, description, tagWrap);
      return anchor;
    };

    const buildEmpty = () => {
      const div = document.createElement("div");
      div.className = "search-empty";
      div.textContent = emptyMessage;
      return div;
    };

    const render = (query) => {
      const normalizedQuery = normalize(query);

      const filtered = normalizedQuery
        ? items.filter((item) => {
            const haystack = normalize([
              item.title,
              item.description,
              item.categoryName,
              item.categorySlug,
              ...(item.tags || []),
            ].join(" "));
            return haystack.includes(normalizedQuery);
          })
        : items;

      const visibleItems = filtered.slice(0, limit);

      summary.innerHTML = normalizedQuery
        ? `검색 결과 <strong>${filtered.length}</strong>개`
        : `전체 <strong>${items.length}</strong>개 게시물`;

      results.innerHTML = "";

      if (visibleItems.length === 0) {
        results.appendChild(buildEmpty());
        return;
      }

      visibleItems.forEach((item) => {
        results.appendChild(buildCard(item));
      });
    };

    input.addEventListener("input", () => {
      render(input.value);
    });
  });
</script>

<style>
  .section-card {
    padding: 1.5rem;
    border: 1px solid #dde5ed;
    border-radius: 20px;
    background: #ffffff;
    box-shadow: 0 10px 30px rgba(19, 36, 59, 0.06);
  }

  .search-block {
    display: grid;
    gap: 1rem;
  }

  .search-block__eyebrow {
    margin: 0 0 0.35rem;
    color: #51719a;
    font-size: 0.9rem;
    font-weight: 700;
  }

  .search-block__title {
    margin: 0 0 0.5rem;
    font-size: 1.25rem;
    font-weight: 800;
    letter-spacing: -0.02em;
  }

  .search-block__description {
    margin: 0;
    color: #58697a;
  }

  .search-app {
    display: grid;
    gap: 1rem;
  }

  .search-input-wrap {
    display: grid;
    gap: 0.45rem;
  }

  .search-input-wrap__label {
    color: #35516e;
    font-size: 0.92rem;
    font-weight: 700;
  }

  .search-input {
    width: 100%;
    padding: 0.9rem 1rem;
    border: 1px solid #d5e0ea;
    border-radius: 14px;
    background: #fbfdff;
    font: inherit;
  }

  .search-input:focus {
    outline: 2px solid rgba(40, 94, 168, 0.18);
    border-color: #8fb4de;
  }

  .search-summary {
    margin: 0;
    color: #58697a;
    font-size: 0.95rem;
  }

  .search-results {
    display: grid;
    gap: 0.9rem;
  }

  .search-card,
  .search-empty {
    display: block;
    padding: 1rem 1.05rem;
    border: 1px solid #e4ebf2;
    border-radius: 16px;
    background: #fbfdff;
  }

  .search-card {
    transition:
      transform 0.2s ease,
      box-shadow 0.2s ease,
      border-color 0.2s ease;
  }

  .search-card:hover {
    transform: translateY(-2px);
    border-color: #bfd3ea;
    box-shadow: 0 10px 24px rgba(24, 62, 105, 0.08);
  }

  .search-card__meta {
    margin: 0 0 0.35rem;
    font-size: 0.82rem;
    font-weight: 700;
    color: #51719a;
  }

  .search-card__title {
    margin: 0 0 0.45rem;
    font-size: 1.05rem;
    line-height: 1.35;
  }

  .search-card__description {
    margin: 0;
    color: #58697a;
    font-size: 0.95rem;
  }

  .search-card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    margin-top: 0.85rem;
  }

  .search-card__tag {
    display: inline-flex;
    align-items: center;
    padding: 0.4rem 0.7rem;
    border-radius: 999px;
    background: #eef5fc;
    color: #244f84;
    font-size: 0.84rem;
    font-weight: 700;
  }

  .search-empty {
    color: #58697a;
  }

  @media (max-width: 820px) {
    .section-card {
      padding: 1.1rem;
      border-radius: 16px;
    }
  }
</style>