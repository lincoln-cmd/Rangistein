---
import { getCollection } from "astro:content";
import SiteLayout from "../../layouts/SiteLayout.astro";
import { getCategoryBySlug } from "../../data/site";
import { getRelatedTags } from "../../utils/tag-utils";
import {
  getNewestTimestamp,
  getUnifiedRecommendationScore,
} from "../../utils/recommendation-score";

export async function getStaticPaths() {
  const posts = await getCollection("posts", ({ data }) => !data.draft);

  const tagMap = new Map<string, typeof posts>();

  for (const post of posts) {
    for (const tag of post.data.tags) {
      const current = tagMap.get(tag) ?? [];
      current.push(post);
      tagMap.set(tag, current);
    }
  }

  return Array.from(tagMap.entries()).map(([tag, taggedPosts]) => ({
    params: { tag },
    props: {
      tag,
      posts: [...taggedPosts].sort((a, b) => {
        if (a.data.featured !== b.data.featured) {
          return a.data.featured ? -1 : 1;
        }

        return String(b.data.publishedAt).localeCompare(String(a.data.publishedAt));
      }),
    },
  }));
}

const { tag, posts } = Astro.props;

const relatedTags = getRelatedTags(tag, posts, 8);

const featuredCount = posts.filter((post: any) => post.data.featured).length;

const newestTimestamp = getNewestTimestamp(posts);

const recommendedPosts = posts
  .map((post: any) => ({
    post,
    score: getUnifiedRecommendationScore(post, newestTimestamp),
  }))
  .sort((a: any, b: any) => {
    if (b.score !== a.score) return b.score - a.score;
    return String(b.post.data.publishedAt).localeCompare(
      String(a.post.data.publishedAt),
    );
  })
  .slice(0, 3)
  .map((item: any) => item.post);
---

<SiteLayout title={`${tag} | 태그 | 랑이슈타인`} currentPath="/tags/">
  <section class="section-card">
    <p class="eyebrow">Tag</p>
    <h1 class="page-title">#{tag}</h1>
    <p class="page-description">
      이 태그가 포함된 게시물은 총 {posts.length}개입니다.
      {featuredCount > 0 ? ` 대표 글 ${featuredCount}개가 포함되어 있습니다.` : ""}
    </p>
  </section>

  {recommendedPosts.length > 0 && (
    <section class="section-card">
      <div class="section-header">
        <div>
          <p class="eyebrow">추천</p>
          <h2 class="section-title">이 태그의 추천 글</h2>
        </div>
        <p class="section-description">
          이 주제를 이해하기 좋은 핵심 글입니다.
        </p>
      </div>

      <div class="post-list">
        {recommendedPosts.map((post: any) => {
          const categoryName =
            getCategoryBySlug(post.data.categorySlug)?.name ??
            post.data.categorySlug;

          return (
            <a href={`/posts/${post.id}/`} class="post-card">
              <p class="post-card__meta">
                {categoryName} · {post.data.publishedAt}
                {post.data.featured ? " · 대표 글" : ""}
              </p>
              <h2 class="post-card__title">{post.data.title}</h2>
              <p class="post-card__description">{post.data.description}</p>
            </a>
          );
        })}
      </div>
    </section>
  )}

  {relatedTags.length > 0 && (
    <section class="section-card">
      <div class="section-header">
        <div>
          <p class="eyebrow">추천</p>
          <h2 class="section-title">함께 자주 쓰인 태그</h2>
        </div>
        <p class="section-description">
          현재 태그와 같은 게시물 안에서 함께 등장한 태그입니다.
        </p>
      </div>

      <div class="tag-wrap">
        {relatedTags.map((item) => (
          <a href={`/tags/${encodeURIComponent(item.tag)}/`} class="tag-chip">
            <span>#{item.tag}</span>
            <span class="tag-chip__count">{item.count}</span>
          </a>
        ))}
      </div>
    </section>
  )}

  <section class="post-list">
    {posts.map((post: any) => {
      const categoryName =
        getCategoryBySlug(post.data.categorySlug)?.name ??
        post.data.categorySlug;

      const otherTags = post.data.tags
        .filter((item: string) => item !== tag)
        .slice(0, 3);

      return (
        <a href={`/posts/${post.id}/`} class="post-card">
          <p class="post-card__meta">
            {categoryName} · {post.data.publishedAt}
            {post.data.featured ? " · 대표 글" : ""}
          </p>
          <h2 class="post-card__title">{post.data.title}</h2>
          <p class="post-card__description">{post.data.description}</p>

          {otherTags.length > 0 && (
            <div class="post-card__tags">
              {otherTags.map((item: string) => (
                <span class="post-card__tag">#{item}</span>
              ))}
            </div>
          )}
        </a>
      );
    })}
  </section>

  <section class="section-card section-card--compact">
    <a href="/tags/" class="back-link">← 태그 목록으로 돌아가기</a>
  </section>
</SiteLayout>

<style>
  .section-card {
    padding: 1.5rem;
    border: 1px solid #dde5ed;
    border-radius: 20px;
    background: #ffffff;
    box-shadow: 0 10px 30px rgba(19, 36, 59, 0.06);
  }

  .section-card--compact {
    padding: 1rem 1.25rem;
  }

  .section-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .eyebrow {
    margin: 0 0 0.4rem;
    color: #51719a;
    font-size: 0.9rem;
    font-weight: 700;
  }

  .page-title {
    margin: 0 0 0.5rem;
    font-size: clamp(1.8rem, 3vw, 2.6rem);
  }

  .page-description,
  .section-description {
    margin: 0;
    color: #58697a;
  }

  .section-title {
    margin: 0;
    font-size: 1.2rem;
    font-weight: 800;
  }

  .tag-wrap {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .tag-chip {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    padding: 0.7rem 1rem;
    border-radius: 999px;
    background: #eef5fc;
    color: #244f84;
    font-weight: 700;
  }

  .tag-chip__count {
    padding: 0.1rem 0.45rem;
    border-radius: 999px;
    background: rgba(36, 79, 132, 0.12);
  }

  .post-list {
    display: grid;
    gap: 1rem;
  }

  .post-card {
    padding: 1.2rem 1.25rem;
    border: 1px solid #dde5ed;
    border-radius: 18px;
    background: #ffffff;
  }

  .post-card__meta {
    margin: 0 0 0.35rem;
    color: #51719a;
    font-size: 0.84rem;
    font-weight: 700;
  }

  .post-card__title {
    margin: 0 0 0.45rem;
    font-size: 1.15rem;
  }

  .post-card__description {
    margin: 0;
    color: #58697a;
  }

  .post-card__tags {
    margin-top: 0.85rem;
  }

  .post-card__tag {
    background: #eef4fb;
    padding: 0.4rem 0.7rem;
    border-radius: 999px;
  }

  .back-link {
    color: #285ea8;
    font-weight: 700;
  }
</style>