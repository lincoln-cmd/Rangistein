---
import { getCollection } from "astro:content";
import SiteLayout from "../../layouts/SiteLayout.astro";

const posts = await getCollection("posts", ({ data }) => !data.draft);

const tagCounts = Array.from(
  posts.flatMap((post) => post.data.tags),
).reduce<Record<string, number>>((acc, tag) => {
  acc[tag] = (acc[tag] ?? 0) + 1;
  return acc;
}, {});

const tags = Object.entries(tagCounts).sort((a, b) => a[0].localeCompare(b[0], "ko"));
---

<SiteLayout title="태그 | 랑이슈타인" currentPath="/tags/">
  <section class="section-card">
    <p class="eyebrow">Tag Index</p>
    <h1 class="page-title">태그</h1>
    <p class="page-description">
      현재 등록된 게시물 태그 목록입니다. 태그를 클릭하면 관련 게시물만 모아볼 수 있습니다.
    </p>
  </section>

  <section class="tag-wrap section-card">
    {tags.map(([tag, count]) => (
      <a href={`/tags/${encodeURIComponent(tag)}/`} class="tag-chip">
        <span>#{tag}</span>
        <span class="tag-chip__count">{count}</span>
      </a>
    ))}
  </section>
</SiteLayout>

<style>
  .section-card {
    padding: 1.5rem;
    border: 1px solid #dde5ed;
    border-radius: 20px;
    background: #ffffff;
    box-shadow: 0 10px 30px rgba(19, 36, 59, 0.06);
  }

  .eyebrow {
    margin: 0 0 0.4rem;
    color: #51719a;
    font-size: 0.9rem;
    font-weight: 700;
  }

  .page-title {
    margin: 0 0 0.5rem;
    font-size: clamp(1.8rem, 3vw, 2.6rem);
    line-height: 1.15;
  }

  .page-description {
    margin: 0;
    color: #58697a;
  }

  .tag-wrap {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .tag-chip {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    padding: 0.7rem 1rem;
    border-radius: 999px;
    background: #eef5fc;
    color: #244f84;
    font-size: 0.94rem;
    font-weight: 700;
    transition:
      transform 0.2s ease,
      box-shadow 0.2s ease,
      background-color 0.2s ease;
  }

  .tag-chip:hover {
    transform: translateY(-1px);
    box-shadow: 0 8px 18px rgba(24, 62, 105, 0.1);
    background: #e4f0fb;
  }

  .tag-chip__count {
    display: inline-flex;
    min-width: 1.5rem;
    justify-content: center;
    padding: 0.1rem 0.45rem;
    border-radius: 999px;
    background: rgba(36, 79, 132, 0.12);
    font-size: 0.82rem;
  }
</style>