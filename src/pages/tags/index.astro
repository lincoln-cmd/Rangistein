---
import SiteLayout from "../../layouts/SiteLayout.astro";
import { posts } from "../../data/site";

const tags = Array.from(new Set(posts.flatMap((post) => post.tags))).sort();
---

<SiteLayout title="태그 | 랑이슈타인" currentPath="/tags/">
  <section class="section-card">
    <p class="eyebrow">Tag Index</p>
    <h1 class="page-title">태그</h1>
    <p class="page-description">
      현재 등록된 게시물 태그 목록입니다. 이후 태그 상세 페이지로 확장할 예정입니다.
    </p>
  </section>

  <section class="tag-wrap section-card">
    {tags.map((tag) => (
      <span class="tag-chip">#{tag}</span>
    ))}
  </section>
</SiteLayout>

<style>
  .section-card {
    padding: 1.5rem;
    border: 1px solid #dde5ed;
    border-radius: 20px;
    background: #ffffff;
    box-shadow: 0 10px 30px rgba(19, 36, 59, 0.06);
  }

  .eyebrow {
    margin: 0 0 0.4rem;
    color: #51719a;
    font-size: 0.9rem;
    font-weight: 700;
  }

  .page-title {
    margin: 0 0 0.5rem;
    font-size: clamp(1.8rem, 3vw, 2.6rem);
    line-height: 1.15;
  }

  .page-description {
    margin: 0;
    color: #58697a;
  }

  .tag-wrap {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .tag-chip {
    display: inline-flex;
    align-items: center;
    padding: 0.7rem 1rem;
    border-radius: 999px;
    background: #eef5fc;
    color: #244f84;
    font-size: 0.94rem;
    font-weight: 700;
  }
</style>