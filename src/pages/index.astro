---
import { getCollection } from "astro:content";
import SiteLayout from "../layouts/SiteLayout.astro";
import SearchClient from "../components/SearchClient.astro";
import {
  categories,
  getCategoryBySlug,
  siteDescription,
  siteTitle,
} from "../data/site";

const allPosts = await getCollection("posts", ({ data }) => !data.draft);

const sortedPosts = [...allPosts].sort((a, b) => {
  if (a.data.featured !== b.data.featured) {
    return a.data.featured ? -1 : 1;
  }

  return String(b.data.publishedAt).localeCompare(String(a.data.publishedAt));
});

const recentPosts = sortedPosts.filter((post) => post.data.type === "latest");
const studyNotes = sortedPosts.filter((post) => post.data.type === "study");
const featuredPosts = sortedPosts.filter((post) => post.data.featured);

const heroFeaturedPost = featuredPosts[0] ?? sortedPosts[0] ?? null;
const recommendedPosts = sortedPosts
  .filter((post) => post.id !== heroFeaturedPost?.id)
  .slice(0, 3);

const latestHighlights = recentPosts.slice(0, 4);
const studyHighlights = studyNotes.slice(0, 4);

const featuredTags = Array.from(
  new Set(sortedPosts.flatMap((post) => post.data.tags)),
).slice(0, 8);

const categoryHighlights = categories
  .map((category) => {
    const posts = sortedPosts.filter((post) => post.data.categorySlug === category.slug);

    return {
      ...category,
      count: posts.length,
      latestPost: posts[0] ?? null,
    };
  })
  .filter((category) => category.count > 0)
  .sort((a, b) => b.count - a.count)
  .slice(0, 6);

const searchItems = sortedPosts.map((post) => ({
  id: post.id,
  title: post.data.title,
  description: post.data.description,
  publishedAt: String(post.data.publishedAt),
  tags: post.data.tags,
  categorySlug: post.data.categorySlug,
  categoryName: getCategoryBySlug(post.data.categorySlug)?.name ?? post.data.categorySlug,
  type: post.data.type,
  featured: post.data.featured,
}));

const getCategoryName = (slug: string) => getCategoryBySlug(slug)?.name ?? slug;
---

<SiteLayout title={siteTitle} description={siteDescription} currentPath="/">
  <header class="hero">
    <div class="hero__overlay">
      <p class="hero__eyebrow">개인 과학 웹 아카이브</p>
      <h1 class="hero__title">랑이슈타인: 랑 집사의 과학 이야기</h1>
      <p class="hero__description">
        수학, 물리, 화학, 생명과학, 지구과학, 천문학을 중심으로
        과학 이론, 최신 동향, 논문 요약, 개인 학습 기록을 정리하는 웹 페이지입니다.
      </p>

      <div class="hero__stats">
        <div class="hero__stat">
          <span class="hero__stat-label">전체 게시물</span>
          <strong>{sortedPosts.length}</strong>
        </div>
        <div class="hero__stat">
          <span class="hero__stat-label">최신 동향</span>
          <strong>{recentPosts.length}</strong>
        </div>
        <div class="hero__stat">
          <span class="hero__stat-label">공부 노트</span>
          <strong>{studyNotes.length}</strong>
        </div>
      </div>
    </div>
  </header>

  <SearchClient
    items={searchItems}
    heading="빠른 검색"
    description="홈에서 바로 게시물을 검색할 수 있습니다."
    placeholder="예: 양자역학, 화학식, 차트, 공부 노트"
    emptyMessage="일치하는 게시물이 없습니다."
    limit={8}
  />

  <section class="intro section-card">
    <h2 class="section-title">프로젝트 소개</h2>
    <p class="section-text">
      랑이슈타인은 과학 관련 지식을 분야별로 정리하고, 개인 학습 과정을 함께 기록하는
      아카이브형 웹 사이트입니다. 단순한 정보 수집형 페이지가 아니라,
      공부 기록과 해설, 요약 콘텐츠를 함께 제공하는 것을 목표로 합니다.
    </p>
  </section>

  {heroFeaturedPost && (
    <section class="section-card featured-section">
      <div class="section-header">
        <div>
          <p class="section-eyebrow">추천</p>
          <h2 class="section-title">대표 글</h2>
        </div>
        <a href={`/posts/${heroFeaturedPost.id}/`} class="section-link">바로 읽기</a>
      </div>

      <div class="featured-layout">
        <a href={`/posts/${heroFeaturedPost.id}/`} class="featured-main-card">
          <p class="featured-main-card__meta">
            {getCategoryName(heroFeaturedPost.data.categorySlug)} · {heroFeaturedPost.data.publishedAt}
            {heroFeaturedPost.data.featured ? " · 대표 글" : ""}
          </p>
          <h3 class="featured-main-card__title">{heroFeaturedPost.data.title}</h3>
          <p class="featured-main-card__description">{heroFeaturedPost.data.description}</p>

          <div class="featured-main-card__tags">
            {heroFeaturedPost.data.tags.slice(0, 4).map((tag) => (
              <span class="signal-chip">#{tag}</span>
            ))}
          </div>
        </a>

        <div class="card-list">
          {recommendedPosts.map((post) => (
            <a href={`/posts/${post.id}/`} class="post-card">
              <p class="post-card__meta">
                {getCategoryName(post.data.categorySlug)} · {post.data.publishedAt}
                {post.data.featured ? " · 대표 글" : ""}
              </p>
              <h3 class="post-card__title">{post.data.title}</h3>
              <p class="post-card__description">{post.data.description}</p>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <section class="content-grid">
    <article class="section-card">
      <div class="section-header">
        <div>
          <p class="section-eyebrow">업데이트</p>
          <h2 class="section-title">최신 연구 동향 · 논문</h2>
        </div>
        <a href="/categories/" class="section-link">전체 보기</a>
      </div>

      <p class="section-subtext">
        최근 정리한 최신 동향, 논문 요약, 이론 기반 해설 글입니다.
      </p>

      <div class="card-list">
        {latestHighlights.map((post) => (
          <a href={`/posts/${post.id}/`} class="post-card">
            <p class="post-card__meta">
              {getCategoryName(post.data.categorySlug)} · {post.data.publishedAt}
              {post.data.featured ? " · 대표 글" : ""}
            </p>
            <h3 class="post-card__title">{post.data.title}</h3>
            <p class="post-card__description">{post.data.description}</p>
          </a>
        ))}
      </div>
    </article>

    <article class="section-card">
      <div class="section-header">
        <div>
          <p class="section-eyebrow">학습 기록</p>
          <h2 class="section-title">개인 공부 게시물</h2>
        </div>
        <a href="/categories/study-notes/" class="section-link">전체 보기</a>
      </div>

      <p class="section-subtext">
        기초 개념 정리, 복습용 노트, 학습 중간 기록을 모아 둔 섹션입니다.
      </p>

      <div class="card-list">
        {studyHighlights.map((post) => (
          <a href={`/posts/${post.id}/`} class="post-card">
            <p class="post-card__meta">
              {getCategoryName(post.data.categorySlug)} · {post.data.publishedAt}
              {post.data.featured ? " · 대표 글" : ""}
            </p>
            <h3 class="post-card__title">{post.data.title}</h3>
            <p class="post-card__description">{post.data.description}</p>
          </a>
        ))}
      </div>
    </article>
  </section>

  <section class="section-card">
    <div class="section-header">
      <div>
        <p class="section-eyebrow">탐색</p>
        <h2 class="section-title">카테고리 바로가기</h2>
      </div>
      <a href="/categories/" class="section-link">카테고리 전체 보기</a>
    </div>

    <div class="category-grid">
      {categoryHighlights.map((category) => (
        <a href={`/categories/${category.slug}/`} class="category-card">
          <p class="category-card__meta">게시물 {category.count}개</p>
          <h3 class="category-card__title">{category.name}</h3>
          <p class="category-card__description">{category.description}</p>

          {category.latestPost && (
            <p class="category-card__latest">
              최신 글: {category.latestPost.data.title}
            </p>
          )}
        </a>
      ))}
    </div>
  </section>

  <section class="section-card">
    <div class="section-header">
      <h2 class="section-title">대표 태그</h2>
      <div class="section-link-row">
        <a href="/tags/" class="section-link">태그 더 보기</a>
        <a href="/search/" class="section-link">검색 페이지</a>
      </div>
    </div>

    <div class="tag-list">
      {featuredTags.map((tag) => (
        <a href={`/tags/${encodeURIComponent(tag)}/`} class="tag-chip">#{tag}</a>
      ))}
    </div>
  </section>

  <footer class="footer section-card">
    <h2 class="section-title">관리자</h2>
    <p class="section-text">
      김동훈 · 과학 이론, 최신 동향, 논문 요약, 개인 학습 기록을 정리하는 개인 웹 아카이브 운영
    </p>
    <p class="footer__meta">
      <a href="/about/">소개</a> ·
      <a href="https://github.com/lincoln-cmd/Rangistein" target="_blank" rel="noreferrer">GitHub</a> ·
      <a href="/admin/index.html">관리자</a>
    </p>
  </footer>
</SiteLayout>

<style>
  .hero {
    position: relative;
    min-height: 320px;
    border-radius: 24px;
    overflow: hidden;
    background:
      linear-gradient(135deg, rgba(21, 45, 86, 0.88), rgba(24, 110, 128, 0.75)),
      radial-gradient(circle at top right, rgba(255, 255, 255, 0.14), transparent 35%),
      #16304a;
  }

  .hero__overlay {
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    gap: 0.9rem;
    min-height: 320px;
    padding: 2rem;
    color: #f7fbff;
  }

  .hero__eyebrow {
    margin: 0;
    font-size: 0.95rem;
    font-weight: 700;
    color: #c8dff3;
  }

  .hero__title {
    margin: 0;
    font-size: clamp(2rem, 4vw, 3.5rem);
    line-height: 1.1;
    letter-spacing: -0.04em;
  }

  .hero__description {
    max-width: 760px;
    margin: 0;
    font-size: 1.02rem;
    color: #e6f0f8;
  }

  .hero__stats {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    margin-top: 0.4rem;
  }

  .hero__stat {
    min-width: 120px;
    padding: 0.8rem 0.95rem;
    border: 1px solid rgba(255, 255, 255, 0.16);
    border-radius: 16px;
    background: rgba(255, 255, 255, 0.08);
    backdrop-filter: blur(6px);
  }

  .hero__stat-label {
    display: block;
    margin-bottom: 0.25rem;
    color: #d9e8f5;
    font-size: 0.82rem;
    font-weight: 700;
  }

  .hero__stat strong {
    font-size: 1.1rem;
  }

  .content-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1.5rem;
  }

  .section-card {
    padding: 1.5rem;
    border: 1px solid #dde5ed;
    border-radius: 20px;
    background: #ffffff;
    box-shadow: 0 10px 30px rgba(19, 36, 59, 0.06);
  }

  .section-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .section-link-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .section-eyebrow {
    margin: 0 0 0.3rem;
    color: #51719a;
    font-size: 0.85rem;
    font-weight: 700;
  }

  .section-title {
    margin: 0;
    font-size: 1.2rem;
    font-weight: 800;
    letter-spacing: -0.02em;
  }

  .section-link {
    font-size: 0.92rem;
    font-weight: 700;
    color: #285ea8;
  }

  .section-text {
    margin: 0;
    color: #4b5b6b;
  }

  .section-subtext {
    margin: 0 0 1rem;
    color: #5d6d7d;
    font-size: 0.95rem;
  }

  .featured-section {
    overflow: hidden;
  }

  .featured-layout {
    display: grid;
    grid-template-columns: minmax(0, 1.3fr) minmax(0, 1fr);
    gap: 1rem;
  }

  .featured-main-card {
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    min-height: 280px;
    padding: 1.4rem;
    border-radius: 20px;
    color: #f7fbff;
    background:
      linear-gradient(145deg, rgba(18, 42, 79, 0.94), rgba(24, 110, 128, 0.86)),
      #17314d;
    box-shadow: 0 14px 32px rgba(20, 44, 81, 0.16);
  }

  .featured-main-card__meta {
    margin: 0 0 0.45rem;
    color: #d4e7f8;
    font-size: 0.84rem;
    font-weight: 700;
  }

  .featured-main-card__title {
    margin: 0 0 0.65rem;
    font-size: clamp(1.35rem, 2vw, 2rem);
    line-height: 1.2;
    letter-spacing: -0.03em;
  }

  .featured-main-card__description {
    margin: 0;
    color: #ebf5fc;
    line-height: 1.7;
  }

  .featured-main-card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    margin-top: 1rem;
  }

  .signal-chip {
    display: inline-flex;
    align-items: center;
    padding: 0.45rem 0.75rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.14);
    color: #f2f8fd;
    font-size: 0.82rem;
    font-weight: 700;
  }

  .card-list {
    display: grid;
    gap: 1rem;
  }

  .post-card {
    display: block;
    padding: 1rem 1.05rem;
    border: 1px solid #e4ebf2;
    border-radius: 16px;
    background: #fbfdff;
    transition:
      transform 0.2s ease,
      box-shadow 0.2s ease,
      border-color 0.2s ease;
  }

  .post-card:hover,
  .category-card:hover,
  .featured-main-card:hover {
    transform: translateY(-2px);
  }

  .post-card:hover,
  .category-card:hover {
    border-color: #bfd3ea;
    box-shadow: 0 10px 24px rgba(24, 62, 105, 0.08);
  }

  .post-card__meta {
    margin: 0 0 0.35rem;
    font-size: 0.82rem;
    font-weight: 700;
    color: #51719a;
  }

  .post-card__title {
    margin: 0 0 0.45rem;
    font-size: 1.05rem;
    line-height: 1.35;
  }

  .post-card__description {
    margin: 0;
    color: #58697a;
    font-size: 0.95rem;
    line-height: 1.65;
  }

  .category-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .category-card {
    display: block;
    padding: 1rem 1.05rem;
    border: 1px solid #e4ebf2;
    border-radius: 16px;
    background: #fbfdff;
    transition:
      transform 0.2s ease,
      box-shadow 0.2s ease,
      border-color 0.2s ease;
  }

  .category-card__meta {
    margin: 0 0 0.35rem;
    color: #51719a;
    font-size: 0.82rem;
    font-weight: 700;
  }

  .category-card__title {
    margin: 0 0 0.45rem;
    font-size: 1rem;
    line-height: 1.35;
  }

  .category-card__description {
    margin: 0;
    color: #58697a;
    font-size: 0.93rem;
    line-height: 1.65;
  }

  .category-card__latest {
    margin: 0.8rem 0 0;
    color: #35516e;
    font-size: 0.88rem;
    font-weight: 700;
    line-height: 1.5;
  }

  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .tag-chip {
    display: inline-flex;
    align-items: center;
    padding: 0.65rem 0.95rem;
    border-radius: 999px;
    background: #eef5fc;
    color: #244f84;
    font-size: 0.92rem;
    font-weight: 700;
  }

  .footer__meta {
    margin: 0.6rem 0 0;
    color: #6a7988;
    font-size: 0.92rem;
  }

  .footer__meta a {
    color: #285ea8;
    font-weight: 700;
  }

  @media (max-width: 1080px) {
    .content-grid,
    .category-grid,
    .featured-layout {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 820px) {
    .hero,
    .hero__overlay {
      min-height: 260px;
    }

    .section-card {
      padding: 1.1rem;
      border-radius: 16px;
    }

    .featured-main-card {
      min-height: 220px;
      padding: 1.1rem;
      border-radius: 16px;
    }
  }

  @media (max-width: 520px) {
    .hero__overlay {
      padding: 1.2rem;
    }

    .hero__description {
      font-size: 0.92rem;
    }

    .section-header {
      flex-direction: column;
      align-items: flex-start;
    }

    .section-title {
      font-size: 1.05rem;
    }

    .post-card__title,
    .category-card__title {
      font-size: 0.98rem;
    }

    .post-card__description,
    .category-card__description {
      font-size: 0.9rem;
    }
  }
</style>