---
import { getCollection } from "astro:content";
import SiteLayout from "../layouts/SiteLayout.astro";
import { siteDescription, siteTitle } from "../data/site";

const allPosts = await getCollection("posts", ({ data }) => !data.draft);

const sortedPosts = [...allPosts].sort((a, b) => {
  if (a.data.featured !== b.data.featured) {
    return a.data.featured ? -1 : 1;
  }

  return b.data.publishedAt.localeCompare(a.data.publishedAt);
});

const recentPosts = sortedPosts.filter((post) => post.data.type === "latest");
const studyNotes = sortedPosts.filter((post) => post.data.type === "study");
const featuredTags = Array.from(
  new Set(sortedPosts.flatMap((post) => post.data.tags)),
).slice(0, 6);
---

<SiteLayout title={siteTitle} description={siteDescription} currentPath="/">
  <header class="hero">
    <div class="hero__overlay">
      <p class="hero__eyebrow">개인 과학 웹 아카이브</p>
      <h1 class="hero__title">랑이슈타인: 랑 집사의 과학 이야기</h1>
      <p class="hero__description">
        수학, 물리, 화학, 생명과학, 지구과학, 천문학을 중심으로
        과학 이론, 최신 동향, 논문 요약, 개인 학습 기록을 정리하는 웹 페이지입니다.
      </p>
    </div>
  </header>

  <section class="intro section-card">
    <h2 class="section-title">프로젝트 소개</h2>
    <p class="section-text">
      랑이슈타인은 과학 관련 지식을 분야별로 정리하고, 개인 학습 과정을 함께 기록하는
      아카이브형 웹 사이트입니다. 단순한 정보 수집형 페이지가 아니라,
      공부 기록과 해설, 요약 콘텐츠를 함께 제공하는 것을 목표로 합니다.
    </p>
  </section>

  <section class="content-grid">
    <article class="section-card">
      <div class="section-header">
        <h2 class="section-title">최신 연구 동향 · 논문</h2>
        <a href="/categories/" class="section-link">전체 보기</a>
      </div>

      <div class="card-list">
        {recentPosts.map((post) => (
          <a href={`/posts/${post.id}/`} class="post-card">
            <p class="post-card__meta">
              {post.data.category} · {post.data.publishedAt}
              {post.data.featured ? " · 대표 글" : ""}
            </p>
            <h3 class="post-card__title">{post.data.title}</h3>
            <p class="post-card__description">{post.data.description}</p>
          </a>
        ))}
      </div>
    </article>

    <article class="section-card">
      <div class="section-header">
        <h2 class="section-title">개인 공부 게시물</h2>
        <a href="/categories/study-notes/" class="section-link">전체 보기</a>
      </div>

      <div class="card-list">
        {studyNotes.map((post) => (
          <a href={`/posts/${post.id}/`} class="post-card">
            <p class="post-card__meta">
              {post.data.category} · {post.data.publishedAt}
              {post.data.featured ? " · 대표 글" : ""}
            </p>
            <h3 class="post-card__title">{post.data.title}</h3>
            <p class="post-card__description">{post.data.description}</p>
          </a>
        ))}
      </div>
    </article>
  </section>

  <section class="section-card">
    <div class="section-header">
      <h2 class="section-title">대표 태그</h2>
      <a href="/tags/" class="section-link">태그 더 보기</a>
    </div>

    <div class="tag-list">
      {featuredTags.map((tag) => (
        <a href="/tags/" class="tag-chip">#{tag}</a>
      ))}
    </div>
  </section>

  <footer class="footer section-card">
    <h2 class="section-title">관리자</h2>
    <p class="section-text">
      김동훈 · 과학 이론, 최신 동향, 논문 요약, 개인 학습 기록을 정리하는 개인 웹 아카이브 운영
    </p>
    <p class="footer__meta">
      <a href="/about/">소개</a> ·
      <a href="https://github.com/lincoln-cmd/Rangistein" target="_blank" rel="noreferrer">GitHub</a> ·
      <a href="/admin/index.html">관리자</a>
    </p>
  </footer>
</SiteLayout>

<style>
  .hero {
    position: relative;
    min-height: 320px;
    border-radius: 24px;
    overflow: hidden;
    background:
      linear-gradient(135deg, rgba(21, 45, 86, 0.88), rgba(24, 110, 128, 0.75)),
      radial-gradient(circle at top right, rgba(255, 255, 255, 0.14), transparent 35%),
      #16304a;
  }

  .hero__overlay {
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    gap: 0.75rem;
    min-height: 320px;
    padding: 2rem;
    color: #f7fbff;
  }

  .hero__eyebrow {
    margin: 0;
    font-size: 0.95rem;
    font-weight: 700;
    color: #c8dff3;
  }

  .hero__title {
    margin: 0;
    font-size: clamp(2rem, 4vw, 3.5rem);
    line-height: 1.1;
    letter-spacing: -0.04em;
  }

  .hero__description {
    max-width: 760px;
    margin: 0;
    font-size: 1.02rem;
    color: #e6f0f8;
  }

  .content-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1.5rem;
  }

  .section-card {
    padding: 1.5rem;
    border: 1px solid #dde5ed;
    border-radius: 20px;
    background: #ffffff;
    box-shadow: 0 10px 30px rgba(19, 36, 59, 0.06);
  }

  .section-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .section-title {
    margin: 0;
    font-size: 1.2rem;
    font-weight: 800;
    letter-spacing: -0.02em;
  }

  .section-link {
    font-size: 0.92rem;
    font-weight: 700;
    color: #285ea8;
  }

  .section-text {
    margin: 0;
    color: #4b5b6b;
  }

  .card-list {
    display: grid;
    gap: 1rem;
  }

  .post-card {
    display: block;
    padding: 1rem 1.05rem;
    border: 1px solid #e4ebf2;
    border-radius: 16px;
    background: #fbfdff;
    transition:
      transform 0.2s ease,
      box-shadow 0.2s ease,
      border-color 0.2s ease;
  }

  .post-card:hover {
    transform: translateY(-2px);
    border-color: #bfd3ea;
    box-shadow: 0 10px 24px rgba(24, 62, 105, 0.08);
  }

  .post-card__meta {
    margin: 0 0 0.35rem;
    font-size: 0.82rem;
    font-weight: 700;
    color: #51719a;
  }

  .post-card__title {
    margin: 0 0 0.45rem;
    font-size: 1.05rem;
    line-height: 1.35;
  }

  .post-card__description {
    margin: 0;
    color: #58697a;
    font-size: 0.95rem;
  }

  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .tag-chip {
    display: inline-flex;
    align-items: center;
    padding: 0.65rem 0.95rem;
    border-radius: 999px;
    background: #eef5fc;
    color: #244f84;
    font-size: 0.92rem;
    font-weight: 700;
  }

  .footer__meta {
    margin: 0.6rem 0 0;
    color: #6a7988;
    font-size: 0.92rem;
  }

  .footer__meta a {
    color: #285ea8;
    font-weight: 700;
  }

  @media (max-width: 1080px) {
    .content-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 820px) {
    .hero,
    .hero__overlay {
      min-height: 260px;
    }

    .section-card {
      padding: 1.1rem;
      border-radius: 16px;
    }
  }

  @media (max-width: 520px) {
    .hero__overlay {
      padding: 1.2rem;
    }

    .hero__description {
      font-size: 0.92rem;
    }

    .section-header {
      flex-direction: column;
      align-items: flex-start;
    }

    .section-title {
      font-size: 1.05rem;
    }

    .post-card__title {
      font-size: 0.98rem;
    }

    .post-card__description {
      font-size: 0.9rem;
    }
  }
</style>