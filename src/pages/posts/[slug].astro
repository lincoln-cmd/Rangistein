---
import { getCollection, render } from "astro:content";
import SiteLayout from "../../layouts/SiteLayout.astro";

export async function getStaticPaths() {
  const posts = await getCollection("posts");

  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<SiteLayout title={`${post.data.title} | 랑이슈타인`}>
  <article class="article-card">
    <p class="eyebrow">{post.data.category} · {post.data.publishedAt}</p>
    <h1 class="article-title">{post.data.title}</h1>
    <p class="article-description">{post.data.description}</p>

    <div class="tag-list">
      {post.data.tags.map((tag: string) => (
        <a href="/tags/" class="tag-chip">#{tag}</a>
      ))}
    </div>

    <div class="article-body">
      <Content />
    </div>

    <div class="article-actions">
      <a href={`/categories/${post.data.categorySlug}/`} class="back-link">
        ← {post.data.category} 목록으로
      </a>
    </div>
  </article>
</SiteLayout>

<style>
  .article-card {
    padding: 1.8rem;
    border: 1px solid #dde5ed;
    border-radius: 24px;
    background: #ffffff;
    box-shadow: 0 10px 30px rgba(19, 36, 59, 0.06);
  }

  .eyebrow {
    margin: 0 0 0.45rem;
    color: #51719a;
    font-size: 0.9rem;
    font-weight: 700;
  }

  .article-title {
    margin: 0 0 0.65rem;
    font-size: clamp(2rem, 3vw, 3rem);
    line-height: 1.12;
    letter-spacing: -0.03em;
  }

  .article-description {
    margin: 0;
    color: #58697a;
    font-size: 1rem;
  }

  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 1.25rem;
  }

  .tag-chip {
    display: inline-flex;
    align-items: center;
    padding: 0.65rem 0.95rem;
    border-radius: 999px;
    background: #eef5fc;
    color: #244f84;
    font-size: 0.92rem;
    font-weight: 700;
  }

  .article-body {
    margin-top: 1.5rem;
  }

  .article-body :global(p) {
    margin: 0 0 1rem;
    color: #2e3c49;
    font-size: 1rem;
    line-height: 1.8;
  }

  .article-actions {
    margin-top: 1.75rem;
    padding-top: 1.25rem;
    border-top: 1px solid #e4ebf2;
  }

  .back-link {
    color: #285ea8;
    font-weight: 700;
  }

  @media (max-width: 820px) {
    .article-card {
      padding: 1.2rem;
      border-radius: 18px;
    }
  }
</style>