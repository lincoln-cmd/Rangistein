---
import { getCollection } from "astro:content";
import { unified } from "unified";
import remarkParse from "remark-parse";
import remarkGfm from "remark-gfm";
import remarkMath from "remark-math";
import remarkRehype from "remark-rehype";
import rehypeMathjax from "rehype-mathjax";
import rehypeStringify from "rehype-stringify";
import { visit } from "unist-util-visit";
import type { Root } from "hast";
import SiteLayout from "../../layouts/SiteLayout.astro";
import VisualizationBlock from "../../components/VisualizationBlock.astro";
import { getCategoryBySlug } from "../../data/site";
import { getRelatedPosts } from "../../utils/related-posts";
import {
  getContentLengthLabel,
  getReadingTimeMinutes,
  isUpdatedPost,
} from "../../utils/post-meta";

export async function getStaticPaths() {
  const posts = await getCollection("posts", ({ data }) => !data.draft);

  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

type TocItem = {
  id: string;
  text: string;
  level: 2 | 3;
};

function slugifyHeading(text: string) {
  return text
    .toLowerCase()
    .trim()
    .replace(/[^\p{L}\p{N}\s-]/gu, "")
    .replace(/\s+/g, "-")
    .replace(/-+/g, "-");
}

function extractText(node: any): string {
  if (!node) return "";
  if (node.type === "text") return node.value ?? "";
  if (Array.isArray(node.children)) {
    return node.children.map((child) => extractText(child)).join("");
  }
  return "";
}

function createHeadingPlugin(toc: TocItem[]) {
  const usedIds = new Map<string, number>();

  return () => (tree: Root) => {
    visit(tree, "element", (node: any) => {
      if (!node || !["h2", "h3"].includes(node.tagName)) return;

      const level = Number(node.tagName.slice(1)) as 2 | 3;
      const text = extractText(node).trim();

      if (!text) return;

      const baseId = slugifyHeading(text) || "section";
      const currentCount = usedIds.get(baseId) ?? 0;
      const id = currentCount === 0 ? baseId : `${baseId}-${currentCount + 1}`;
      usedIds.set(baseId, currentCount + 1);

      node.properties = {
        ...(node.properties ?? {}),
        id,
      };

      node.children = [
        ...(node.children ?? []),
        {
          type: "element",
          tagName: "a",
          properties: {
            href: `#${id}`,
            className: ["heading-anchor"],
            "aria-label": `${text} 링크`,
          },
          children: [
            {
              type: "text",
              value: "#",
            },
          ],
        },
      ];

      toc.push({
        id,
        text,
        level,
      });
    });
  };
}

const { post } = Astro.props;
const references = post.data.references ?? [];
const visualizations = post.data.visualizations ?? [];

const category = getCategoryBySlug(post.data.categorySlug);
const categoryName = category?.name ?? post.data.categorySlug;

const allPosts = (await getCollection("posts", ({ data }) => !data.draft)).sort((a, b) =>
  String(b.data.publishedAt).localeCompare(String(a.data.publishedAt)),
);

const currentIndex = allPosts.findIndex((item) => item.id === post.id);
const previousPost = currentIndex > 0 ? allPosts[currentIndex - 1] : null;
const nextPost =
  currentIndex >= 0 && currentIndex < allPosts.length - 1
    ? allPosts[currentIndex + 1]
    : null;

const previousCategoryName = previousPost
  ? (getCategoryBySlug(previousPost.data.categorySlug)?.name ?? previousPost.data.categorySlug)
  : null;

const nextCategoryName = nextPost
  ? (getCategoryBySlug(nextPost.data.categorySlug)?.name ?? nextPost.data.categorySlug)
  : null;

const relatedPosts = getRelatedPosts(post, allPosts, 3);

const pageTitle = `${post.data.title} | 랑이슈타인`;
const pageDescription = post.data.description;

const siteUrl = Astro.site ?? new URL("https://rangistein.pages.dev");
const postUrl = new URL(`/posts/${post.id}/`, siteUrl).toString();

const postStructuredData = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: post.data.title,
  description: post.data.description,
  url: postUrl,
  datePublished: String(post.data.publishedAt),
  dateModified: String(post.data.updatedAt ?? post.data.publishedAt),
  inLanguage: "ko-KR",
  articleSection: categoryName,
  keywords: post.data.tags.join(", "),
  author: {
    "@type": "Person",
    name: "김동훈",
  },
  publisher: {
    "@type": "Organization",
    name: "랑이슈타인",
  },
};


const rawBody = post.body ?? "";
const readingTimeMinutes = getReadingTimeMinutes(rawBody);
const contentLengthLabel = getContentLengthLabel(rawBody);
const hasUpdated = isUpdatedPost(
  String(post.data.publishedAt),
  post.data.updatedAt ? String(post.data.updatedAt) : undefined,
);
const markerRegex = /\{\{viz:([\w-]+)\}\}/g;

type Segment =
  | { type: "markdown"; content: string }
  | { type: "viz"; id: string };

const segments: Segment[] = [];
let lastIndex = 0;
let match: RegExpExecArray | null;

while ((match = markerRegex.exec(rawBody)) !== null) {
  const before = rawBody.slice(lastIndex, match.index);
  if (before.trim()) {
    segments.push({ type: "markdown", content: before });
  }

  segments.push({ type: "viz", id: match[1] });
  lastIndex = match.index + match[0].length;
}

const rest = rawBody.slice(lastIndex);
if (rest.trim()) {
  segments.push({ type: "markdown", content: rest });
}

if (segments.length === 0 && rawBody.trim()) {
  segments.push({ type: "markdown", content: rawBody });
}

const toc: TocItem[] = [];

async function renderMarkdownSegment(content: string) {
  const file = await unified()
    .use(remarkParse)
    .use(remarkGfm)
    .use(remarkMath)
    .use(remarkRehype)
    .use(rehypeMathjax, {
      tex: {
        packages: { "[+]": ["mhchem"] },
      },
    })
    .use(createHeadingPlugin(toc))
    .use(rehypeStringify)
    .process(content);

  return String(file);
}

const renderedSegments = await Promise.all(
  segments.map(async (segment) => {
    if (segment.type === "markdown") {
      return {
        type: "markdown" as const,
        html: await renderMarkdownSegment(segment.content),
      };
    }

    return segment;
  }),
);

const vizMap = new Map(visualizations.map((viz: any) => [viz.id, viz]));
---

<SiteLayout
  title={pageTitle}
  description={pageDescription}
  ogType="article"
  publishedTime={String(post.data.publishedAt)}
  modifiedTime={String(post.data.updatedAt ?? post.data.publishedAt)}
  tags={post.data.tags}
  structuredData={postStructuredData}
>
  <article class="article-card">
    <p class="eyebrow">{categoryName} · {post.data.publishedAt}</p>
    <h1 class="article-title">{post.data.title}</h1>
    <p class="article-description">{post.data.description}</p>

    <dl class="meta-grid">
      <div>
        <dt>분류</dt>
        <dd>{categoryName}</dd>
      </div>
      <div>
        <dt>발행일</dt>
        <dd>{post.data.publishedAt}</dd>
      </div>
      <div>
        <dt>수정일</dt>
        <dd>{post.data.updatedAt ?? "-"}</dd>
      </div>
      <div>
        <dt>대표 글</dt>
        <dd>{post.data.featured ? "예" : "아니오"}</dd>
      </div>
      <div>
        <dt>예상 읽기 시간</dt>
        <dd>약 {readingTimeMinutes}분 · {contentLengthLabel}</dd>
      </div>
      <div>
        <dt>업데이트 여부</dt>
        <dd>{hasUpdated ? "수정됨" : "초판"}</dd>
      </div>
    </dl>

    {toc.length > 0 && (
      <nav class="toc-card" aria-label="게시물 목차">
        <p class="toc-card__eyebrow">목차</p>
        <ol class="toc-list">
          {toc.map((item) => (
            <li class={`toc-list__item toc-list__item--level-${item.level}`}>
              <a href={`#${item.id}`}>{item.text}</a>
            </li>
          ))}
        </ol>
      </nav>
    )}

    <div class="tag-list">
      {post.data.tags.map((tag: string) => (
        <a href={`/tags/${encodeURIComponent(tag)}/`} class="tag-chip">#{tag}</a>
      ))}
    </div>

    <div class="article-body">
      {renderedSegments.map((segment) =>
        segment.type === "markdown" ? (
          <Fragment set:html={segment.html} />
        ) : vizMap.has(segment.id) ? (
          <VisualizationBlock viz={vizMap.get(segment.id)} />
        ) : (
          <div class="viz-missing">
            시각화 블록 <code>{segment.id}</code> 를 찾을 수 없습니다.
          </div>
        ),
      )}
    </div>

    {references.length > 0 && (
      <section class="references">
        <h2 class="references__title">참고 자료</h2>
        <ul class="references__list">
          {references.map((reference) => (
            <li>
              <a href={reference.url} target="_blank" rel="noreferrer">
                {reference.title}
              </a>
            </li>
          ))}
        </ul>
      </section>
    )}

    {relatedPosts.length > 0 && (
      <section class="related-posts" aria-label="관련 글">
        <div class="related-posts__header">
          <p class="related-posts__eyebrow">추천</p>
          <h2 class="related-posts__title">관련 글</h2>
        </div>

        <div class="related-posts__grid">
          {relatedPosts.map(({ post: related, sharedTags, sameCategory, sameType }) => {
            const relatedCategoryName =
              getCategoryBySlug(related.data.categorySlug)?.name ?? related.data.categorySlug;

            return (
              <a href={`/posts/${related.id}/`} class="related-posts__card">
                <p class="related-posts__meta">
                  {relatedCategoryName} · {related.data.publishedAt}
                  {related.data.featured ? " · 대표 글" : ""}
                </p>
                <h3 class="related-posts__card-title">{related.data.title}</h3>
                <p class="related-posts__description">{related.data.description}</p>

                <div class="related-posts__signals">
                  {sameCategory && (
                    <span class="related-posts__signal related-posts__signal--accent">
                      같은 카테고리
                    </span>
                  )}

                  {sameType && (
                    <span class="related-posts__signal">
                      같은 형식
                    </span>
                  )}

                  {sharedTags.slice(0, 3).map((tag) => (
                    <span class="related-posts__signal">#{tag}</span>
                  ))}
                </div>
              </a>
            );
          })}
        </div>
      </section>
    )}

    {(previousPost || nextPost) && (
      <section class="post-pagination" aria-label="이전 다음 글">
        {previousPost ? (
          <a href={`/posts/${previousPost.id}/`} class="post-pagination__card">
            <p class="post-pagination__label">이전 글</p>
            <p class="post-pagination__meta">
              {previousCategoryName} · {previousPost.data.publishedAt}
            </p>
            <h2 class="post-pagination__title">{previousPost.data.title}</h2>
            <p class="post-pagination__description">{previousPost.data.description}</p>
          </a>
        ) : (
          <div class="post-pagination__card post-pagination__card--empty"></div>
        )}

        {nextPost ? (
          <a href={`/posts/${nextPost.id}/`} class="post-pagination__card">
            <p class="post-pagination__label">다음 글</p>
            <p class="post-pagination__meta">
              {nextCategoryName} · {nextPost.data.publishedAt}
            </p>
            <h2 class="post-pagination__title">{nextPost.data.title}</h2>
            <p class="post-pagination__description">{nextPost.data.description}</p>
          </a>
        ) : (
          <div class="post-pagination__card post-pagination__card--empty"></div>
        )}
      </section>
    )}

    <section class="article-actions" aria-label="게시물 탐색">
      <div class="article-actions__header">
        <p class="article-actions__eyebrow">다음 탐색</p>
        <h2 class="article-actions__title">이 글과 이어서 볼 만한 경로</h2>
      </div>

      <div class="article-actions__grid">
        <a href={`/categories/${post.data.categorySlug}/`} class="article-action-card">
          <p class="article-action-card__label">카테고리</p>
          <h3 class="article-action-card__title">{categoryName}</h3>
          <p class="article-action-card__description">
            같은 분야의 글을 더 살펴봅니다.
          </p>
        </a>

        {post.data.tags.slice(0, 2).map((tag: string) => (
          <a href={`/tags/${encodeURIComponent(tag)}/`} class="article-action-card">
            <p class="article-action-card__label">태그</p>
            <h3 class="article-action-card__title">#{tag}</h3>
            <p class="article-action-card__description">
              같은 주제어가 포함된 글을 모아 봅니다.
            </p>
          </a>
        ))}

        <a href="/search/" class="article-action-card">
          <p class="article-action-card__label">검색</p>
          <h3 class="article-action-card__title">게시물 검색</h3>
          <p class="article-action-card__description">
            키워드와 카테고리 필터로 다른 글을 찾습니다.
          </p>
        </a>
      </div>
    </section>
  </article>
</SiteLayout>

