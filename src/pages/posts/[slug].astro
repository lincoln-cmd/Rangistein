---
import { getCollection } from "astro:content";
import { unified } from "unified";
import remarkParse from "remark-parse";
import remarkGfm from "remark-gfm";
import remarkMath from "remark-math";
import remarkRehype from "remark-rehype";
import rehypeKatex from "rehype-katex";
import rehypeStringify from "rehype-stringify";
import SiteLayout from "../../layouts/SiteLayout.astro";
import VisualizationBlock from "../../components/VisualizationBlock.astro";

export async function getStaticPaths() {
  const posts = await getCollection("posts", ({ data }) => !data.draft);

  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const references = post.data.references ?? [];
const visualizations = post.data.visualizations ?? [];

const pageTitle = `${post.data.title} | 랑이슈타인`;
const pageDescription = post.data.description;

const rawBody = post.body ?? "";
const markerRegex = /\{\{viz:([\w-]+)\}\}/g;

type Segment =
  | { type: "markdown"; content: string }
  | { type: "viz"; id: string };

const segments: Segment[] = [];
let lastIndex = 0;
let match: RegExpExecArray | null;

while ((match = markerRegex.exec(rawBody)) !== null) {
  const before = rawBody.slice(lastIndex, match.index);
  if (before.trim()) {
    segments.push({ type: "markdown", content: before });
  }

  segments.push({ type: "viz", id: match[1] });
  lastIndex = match.index + match[0].length;
}

const rest = rawBody.slice(lastIndex);
if (rest.trim()) {
  segments.push({ type: "markdown", content: rest });
}

if (segments.length === 0 && rawBody.trim()) {
  segments.push({ type: "markdown", content: rawBody });
}

async function renderMarkdownSegment(content: string) {
  const file = await unified()
    .use(remarkParse)
    .use(remarkGfm)
    .use(remarkMath)
    .use(remarkRehype)
    .use(rehypeKatex)
    .use(rehypeStringify)
    .process(content);

  return String(file);
}

const renderedSegments = await Promise.all(
  segments.map(async (segment) => {
    if (segment.type === "markdown") {
      return {
        type: "markdown" as const,
        html: await renderMarkdownSegment(segment.content),
      };
    }

    return segment;
  }),
);

const vizMap = new Map(visualizations.map((viz: any) => [viz.id, viz]));
---

<SiteLayout title={pageTitle} description={pageDescription}>
  <article class="article-card">
    <p class="eyebrow">{post.data.category} · {post.data.publishedAt}</p>
    <h1 class="article-title">{post.data.title}</h1>
    <p class="article-description">{post.data.description}</p>

    <dl class="meta-grid">
      <div>
        <dt>분류</dt>
        <dd>{post.data.category}</dd>
      </div>
      <div>
        <dt>발행일</dt>
        <dd>{post.data.publishedAt}</dd>
      </div>
      <div>
        <dt>수정일</dt>
        <dd>{post.data.updatedAt ?? "-"}</dd>
      </div>
      <div>
        <dt>대표 글</dt>
        <dd>{post.data.featured ? "예" : "아니오"}</dd>
      </div>
    </dl>

    <div class="tag-list">
      {post.data.tags.map((tag: string) => (
        <a href={`/tags/${encodeURIComponent(tag)}/`} class="tag-chip">#{tag}</a>
      ))}
    </div>

    <div class="article-body">
      {renderedSegments.map((segment) =>
        segment.type === "markdown" ? (
          <Fragment set:html={segment.html} />
        ) : vizMap.has(segment.id) ? (
          <VisualizationBlock viz={vizMap.get(segment.id)} />
        ) : (
          <div class="viz-missing">
            시각화 블록 <code>{segment.id}</code> 를 찾을 수 없습니다.
          </div>
        ),
      )}
    </div>

    {references.length > 0 && (
      <section class="references">
        <h2 class="references__title">참고 자료</h2>
        <ul class="references__list">
          {references.map((reference) => (
            <li>
              <a href={reference.url} target="_blank" rel="noreferrer">
                {reference.title}
              </a>
            </li>
          ))}
        </ul>
      </section>
    )}

    <div class="article-actions">
      <a href={`/categories/${post.data.categorySlug}/`} class="back-link">
        ← {post.data.category} 목록으로
      </a>
    </div>
  </article>
</SiteLayout>

<style>
  .article-card {
    padding: 1.8rem;
    border: 1px solid #dde5ed;
    border-radius: 24px;
    background: #ffffff;
    box-shadow: 0 10px 30px rgba(19, 36, 59, 0.06);
  }

  .eyebrow {
    margin: 0 0 0.45rem;
    color: #51719a;
    font-size: 0.9rem;
    font-weight: 700;
  }

  .article-title {
    margin: 0 0 0.65rem;
    font-size: clamp(2rem, 3vw, 3rem);
    line-height: 1.12;
    letter-spacing: -0.03em;
  }

  .article-description {
    margin: 0;
    color: #58697a;
    font-size: 1rem;
  }

  .meta-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.85rem 1rem;
    margin: 1.5rem 0 0;
    padding: 1rem 1.1rem;
    border: 1px solid #e4ebf2;
    border-radius: 16px;
    background: #f9fbfe;
  }

  .meta-grid dt {
    margin: 0 0 0.2rem;
    color: #51719a;
    font-size: 0.85rem;
    font-weight: 700;
  }

  .meta-grid dd {
    margin: 0;
    color: #2e3c49;
  }

  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 1.25rem;
  }

  .tag-chip {
    display: inline-flex;
    align-items: center;
    padding: 0.65rem 0.95rem;
    border-radius: 999px;
    background: #eef5fc;
    color: #244f84;
    font-size: 0.92rem;
    font-weight: 700;
  }

  .article-body {
    margin-top: 1.5rem;
  }

  .article-body :global(p) {
    margin: 0 0 1rem;
    color: #2e3c49;
    font-size: 1rem;
    line-height: 1.8;
  }

  .article-body :global(img) {
    display: block;
    width: 100%;
    max-width: 100%;
    height: auto;
    margin: 1.4rem auto;
    border: 1px solid #e4ebf2;
    border-radius: 18px;
    background: #f8fbfe;
    box-shadow: 0 10px 24px rgba(19, 36, 59, 0.08);
  }

  .article-body :global(figure) {
    margin: 1.6rem 0;
  }

  .article-body :global(figure img) {
    margin: 0;
  }

  .article-body :global(figcaption) {
    margin-top: 0.7rem;
    color: #6a7988;
    font-size: 0.92rem;
    line-height: 1.6;
    text-align: center;
  }

  .article-body :global(blockquote) {
    margin: 1.4rem 0;
    padding: 0.9rem 1rem;
    border-left: 4px solid #bfd3ea;
    background: #f7fbff;
    color: #476072;
  }

  .article-body :global(ul),
  .article-body :global(ol) {
    margin: 1rem 0 1rem 1.25rem;
    color: #2e3c49;
  }

  .article-body :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 1.5rem 0;
    overflow: hidden;
    border: 1px solid #dde5ed;
    border-radius: 14px;
    background: #ffffff;
  }

  .article-body :global(th),
  .article-body :global(td) {
    padding: 0.8rem 0.9rem;
    border-bottom: 1px solid #e4ebf2;
    text-align: left;
    vertical-align: top;
  }

  .article-body :global(th) {
    background: #f5f9fd;
    color: #35516e;
    font-weight: 700;
  }

  .article-body :global(tr:last-child td) {
    border-bottom: none;
  }

  .article-body :global(.katex-display) {
    margin: 1.4rem 0;
    overflow-x: auto;
    overflow-y: hidden;
    padding: 0.2rem 0;
  }

  .article-body :global(.katex) {
    font-size: 1.05em;
  }

  .viz-missing {
    margin: 1.5rem 0;
    padding: 1rem;
    border: 1px dashed #d7a3a3;
    border-radius: 14px;
    background: #fff7f7;
    color: #8a4a4a;
  }

  .references {
    margin-top: 1.75rem;
    padding: 1.2rem;
    border: 1px solid #e4ebf2;
    border-radius: 18px;
    background: #fbfdff;
  }

  .references__title {
    margin: 0 0 0.75rem;
    font-size: 1.1rem;
  }

  .references__list {
    margin: 0;
    padding-left: 1.2rem;
  }

  .references__list li + li {
    margin-top: 0.5rem;
  }

  .references__list a {
    color: #285ea8;
  }

  .article-actions {
    margin-top: 1.75rem;
    padding-top: 1.25rem;
    border-top: 1px solid #e4ebf2;
  }

  .back-link {
    color: #285ea8;
    font-weight: 700;
  }

  @media (max-width: 820px) {
    .article-card {
      padding: 1.2rem;
      border-radius: 18px;
    }

    .meta-grid {
      grid-template-columns: 1fr;
    }
  }
</style>