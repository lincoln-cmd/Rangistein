---
import SiteLayout from "../layouts/SiteLayout.astro";
---

<SiteLayout title="404 | 랑이슈타인" description="요청한 페이지를 찾을 수 없습니다.">
  <section class="section-card not-found">
    <p class="eyebrow">404 Not Found</p>
    <h1 class="page-title">페이지를 찾을 수 없습니다</h1>
    <p class="page-description">
      주소가 잘못되었거나, 이동 또는 삭제된 페이지일 수 있습니다.
    </p>

    <div class="action-row">
      <a href="/" class="action-link">홈으로 이동</a>
      <a href="/categories/" class="action-link">카테고리 보기</a>
      <a href="/tags/" class="action-link">태그 보기</a>
    </div>
  </section>
</SiteLayout>

<style>
  .section-card {
    padding: 1.8rem;
    border: 1px solid #dde5ed;
    border-radius: 24px;
    background: #ffffff;
    box-shadow: 0 10px 30px rgba(19, 36, 59, 0.06);
  }

  .not-found {
    min-height: 320px;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .eyebrow {
    margin: 0 0 0.4rem;
    color: #51719a;
    font-size: 0.9rem;
    font-weight: 700;
  }

  .page-title {
    margin: 0 0 0.6rem;
    font-size: clamp(2rem, 3vw, 3rem);
    line-height: 1.12;
    letter-spacing: -0.03em;
  }

  .page-description {
    margin: 0;
    color: #58697a;
  }

  .action-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    margin-top: 1.4rem;
  }

  .action-link {
    display: inline-flex;
    align-items: center;
    padding: 0.75rem 1rem;
    border-radius: 999px;
    background: #eef5fc;
    color: #244f84;
    font-weight: 700;
  }
</style>