---
import { getCollection } from "astro:content";
import SiteLayout from "../layouts/SiteLayout.astro";
import SearchClient from "../components/SearchClient.astro";
import { getCategoryBySlug } from "../data/site";

const posts = await getCollection("posts", ({ data }) => !data.draft);

const searchItems = [...posts]
  .sort((a, b) => {
    if (a.data.featured !== b.data.featured) {
      return a.data.featured ? -1 : 1;
    }

    return String(b.data.publishedAt).localeCompare(String(a.data.publishedAt));
  })
  .map((post) => ({
    id: post.id,
    title: post.data.title,
    description: post.data.description,
    publishedAt: String(post.data.publishedAt),
    tags: post.data.tags,
    categorySlug: post.data.categorySlug,
    categoryName: getCategoryBySlug(post.data.categorySlug)?.name ?? post.data.categorySlug,
    type: post.data.type,
    featured: post.data.featured,
  }));
---

<SiteLayout
  title="검색 | 랑이슈타인"
  description="게시물 제목, 설명, 태그, 카테고리 기준으로 랑이슈타인의 글을 빠르게 찾을 수 있습니다."
>
  <section class="search-page-intro section-card">
    <p class="search-page-intro__eyebrow">Search</p>
    <h1 class="search-page-intro__title">게시물 검색</h1>
    <p class="search-page-intro__description">
      제목, 설명, 태그, 카테고리 기준으로 검색할 수 있습니다.
      검색어 입력 후 카테고리 필터를 함께 적용하면 원하는 글을 더 빠르게 찾을 수 있습니다.
    </p>
  </section>

  <SearchClient
    items={searchItems}
    heading="검색 도구"
    description="검색어와 카테고리 필터를 조합해 게시물을 탐색해 보세요."
    placeholder="예: 양자역학, 수식, 화학식, 공부 노트"
    emptyMessage="다른 검색어를 입력하거나 카테고리 필터를 변경해 보세요."
    limit={100}
  />
</SiteLayout>

<style>
  .section-card {
    padding: 1.5rem;
    border: 1px solid #dde5ed;
    border-radius: 20px;
    background: #ffffff;
    box-shadow: 0 10px 30px rgba(19, 36, 59, 0.06);
  }

  .search-page-intro__eyebrow {
    margin: 0 0 0.35rem;
    color: #51719a;
    font-size: 0.9rem;
    font-weight: 700;
  }

  .search-page-intro__title {
    margin: 0 0 0.55rem;
    font-size: clamp(1.9rem, 3vw, 2.7rem);
    line-height: 1.15;
    letter-spacing: -0.03em;
  }

  .search-page-intro__description {
    margin: 0;
    color: #58697a;
    line-height: 1.7;
  }

  @media (max-width: 820px) {
    .section-card {
      padding: 1.1rem;
      border-radius: 16px;
    }
  }
</style>