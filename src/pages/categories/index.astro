---
import { getCollection } from "astro:content";
import SiteLayout from "../../layouts/SiteLayout.astro";
import { categories } from "../../data/site";

const posts = await getCollection("posts", ({ data }) => !data.draft);

const categoryCards = categories.map((category) => {
  const categoryPosts = posts
    .filter((post) => post.data.categorySlug === category.slug)
    .sort((a, b) => String(b.data.publishedAt).localeCompare(String(a.data.publishedAt)));

  const latestPost = categoryPosts[0] ?? null;

  const featuredTags = Array.from(
    new Set(categoryPosts.flatMap((post) => post.data.tags)),
  ).slice(0, 3);

  return {
    ...category,
    count: categoryPosts.length,
    latestPost,
    featuredTags,
  };
});

const totalPostCount = posts.length;
const topCategory = [...categoryCards].sort((a, b) => b.count - a.count)[0] ?? null;
---

<SiteLayout
  title="카테고리 | 랑이슈타인"
  description="랑이슈타인에서 다루는 과학 분야와 학습 노트 분류를 한눈에 볼 수 있습니다."
  currentPath="/categories/"
>
  <section class="section-card hero-card">
    <p class="eyebrow">Category Index</p>
    <h1 class="page-title">카테고리</h1>
    <p class="page-description">
      랑이슈타인에서 다루는 과학 분야와 학습 노트 분류를 한눈에 볼 수 있습니다.
    </p>
  </section>

  <section class="summary-grid">
    <div class="summary-card">
      <p class="summary-card__label">전체 카테고리</p>
      <strong class="summary-card__value">{categoryCards.length}개</strong>
    </div>

    <div class="summary-card">
      <p class="summary-card__label">전체 게시물</p>
      <strong class="summary-card__value">{totalPostCount}개</strong>
    </div>

    <div class="summary-card">
      <p class="summary-card__label">가장 많은 카테고리</p>
      <strong class="summary-card__value">
        {topCategory ? topCategory.name : "-"}
      </strong>
    </div>
  </section>

  <section class="category-grid">
    {categoryCards.map((category) => (
      <a class="category-card" href={`/categories/${category.slug}/`}>
        <p class="category-card__meta">게시물 {category.count}개</p>
        <h2 class="category-card__title">{category.name}</h2>
        <p class="category-card__description">{category.description}</p>

        {category.latestPost && (
          <p class="category-card__latest">
            최신 글: {category.latestPost.data.title}
          </p>
        )}

        {category.featuredTags.length > 0 && (
          <div class="tag-row">
            {category.featuredTags.map((tag) => (
              <span class="tag-chip">#{tag}</span>
            ))}
          </div>
        )}
      </a>
    ))}
  </section>
</SiteLayout>

<style>
  .section-card {
    padding: 1.5rem;
    border: 1px solid #dde5ed;
    border-radius: 20px;
    background: #ffffff;
    box-shadow: 0 10px 30px rgba(19, 36, 59, 0.06);
  }

  .hero-card {
    background:
      linear-gradient(135deg, rgba(21, 45, 86, 0.04), rgba(24, 110, 128, 0.05)),
      #ffffff;
  }

  .eyebrow {
    margin: 0 0 0.4rem;
    color: #51719a;
    font-size: 0.9rem;
    font-weight: 700;
  }

  .page-title {
    margin: 0 0 0.6rem;
    font-size: clamp(1.9rem, 3vw, 2.8rem);
    line-height: 1.15;
    letter-spacing: -0.03em;
  }

  .page-description {
    margin: 0;
    color: #58697a;
  }

  .summary-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .summary-card {
    padding: 1.15rem 1.2rem;
    border: 1px solid #dde5ed;
    border-radius: 18px;
    background: #ffffff;
    box-shadow: 0 10px 30px rgba(19, 36, 59, 0.06);
  }

  .summary-card__label {
    margin: 0 0 0.35rem;
    color: #51719a;
    font-size: 0.88rem;
    font-weight: 700;
  }

  .summary-card__value {
    font-size: 1.15rem;
    line-height: 1.3;
  }

  .category-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  .category-card {
    display: block;
    padding: 1.4rem;
    border: 1px solid #dde5ed;
    border-radius: 20px;
    background: #ffffff;
    box-shadow: 0 10px 30px rgba(19, 36, 59, 0.06);
    text-decoration: none;
    color: inherit;
    transition:
      transform 0.2s ease,
      box-shadow 0.2s ease;
  }

  .category-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 14px 34px rgba(19, 36, 59, 0.1);
  }

  .category-card__meta {
    margin: 0 0 0.5rem;
    color: #51719a;
    font-size: 0.9rem;
    font-weight: 700;
  }

  .category-card__title {
    margin: 0 0 0.65rem;
    font-size: 1.6rem;
    line-height: 1.2;
    letter-spacing: -0.02em;
  }

  .category-card__description {
    margin: 0;
    color: #58697a;
    line-height: 1.7;
  }

  .category-card__latest {
    margin: 0.9rem 0 0;
    color: #35516e;
    font-size: 0.92rem;
    font-weight: 700;
    line-height: 1.55;
  }

  .tag-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    margin-top: 1rem;
  }

  .tag-chip {
    display: inline-flex;
    align-items: center;
    padding: 0.5rem 0.8rem;
    border-radius: 999px;
    background: #eef5fc;
    color: #244f84;
    font-size: 0.84rem;
    font-weight: 700;
  }

  @media (max-width: 820px) {
    .summary-grid,
    .category-grid {
      grid-template-columns: 1fr;
    }
  }
</style>