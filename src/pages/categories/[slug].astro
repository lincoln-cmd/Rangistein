---
import { getCollection } from "astro:content";
import SiteLayout from "../../layouts/SiteLayout.astro";
import { categories, getCategoryBySlug } from "../../data/site";
import {
  getNewestTimestamp,
  getUnifiedRecommendationScore,
} from "../../utils/recommendation-score";

export async function getStaticPaths() {
  return categories.map((category) => ({
    params: { slug: category.slug },
  }));
}

const { slug } = Astro.params;

if (!slug) {
  throw new Error("Missing category slug.");
}

const category = getCategoryBySlug(slug);

if (!category) {
  throw new Error(`Unknown category slug: ${slug}`);
}

const posts = (await getCollection("posts", ({ data }) => !data.draft))
  .filter((post) => post.data.categorySlug === slug)
  .sort((a, b) => String(b.data.publishedAt).localeCompare(String(a.data.publishedAt)));

const newestTimestamp = getNewestTimestamp(posts);

const recommendedPosts = posts
  .map((post) => ({
    post,
    score: getUnifiedRecommendationScore(post, newestTimestamp),
  }))
  .sort((a, b) => {
    if (b.score !== a.score) return b.score - a.score;
    return String(b.post.data.publishedAt).localeCompare(String(a.post.data.publishedAt));
  })
  .slice(0, 3)
  .map((item) => item.post);

const featuredTags = Array.from(
  new Set(posts.flatMap((post) => post.data.tags)),
).slice(0, 4);

function toTimestamp(value: string) {
  const parsed = Date.parse(String(value));
  return Number.isNaN(parsed) ? 0 : parsed;
}

function getRecencyBonus(publishedAt: string) {
  const publishedTimestamp = toTimestamp(publishedAt);

  if (!publishedTimestamp || !newestTimestamp) return 0;

  const diffDays = Math.max(
    0,
    (newestTimestamp - publishedTimestamp) / (1000 * 60 * 60 * 24),
  );

  if (diffDays <= 7) return 12;
  if (diffDays <= 30) return 9;
  if (diffDays <= 90) return 6;
  if (diffDays <= 180) return 3;

  return 1;
}

function isRecentPost(publishedAt: string) {
  return getRecencyBonus(publishedAt) >= 9;
}

function getCategoryRecommendationSignals(post: (typeof posts)[number]) {
  const signals: Array<{ label: string; accent?: boolean }> = [];

  signals.push({
    label: "카테고리 핵심 글",
    accent: true,
  });

  if (post.data.featured) {
    signals.push({
      label: "대표 글",
    });
  }

  if (isRecentPost(String(post.data.publishedAt))) {
    signals.push({
      label: "최신 글",
    });
  }

  return signals.slice(0, 3);
}
---

<SiteLayout
  title={`${category.name} | 랑이슈타인`}
  description={category.description}
  currentPath={`/categories/${category.slug}/`}
>
  <section class="section-card hero-card">
    <p class="eyebrow">Category</p>
    <h1 class="page-title">{category.name}</h1>
    <p class="page-description">{category.description}</p>
  </section>

  {recommendedPosts.length > 0 && (
    <section class="section-card">
      <div class="section-header">
        <div>
          <p class="eyebrow">추천</p>
          <h2 class="section-title">이 카테고리의 추천 글</h2>
        </div>
        <p class="section-description">
          이 분야를 이해하기 좋은 핵심 글입니다.
        </p>
      </div>

      <div class="post-list">
        {recommendedPosts.map((post) => {
          const signals = getCategoryRecommendationSignals(post);

          return (
            <article class="post-card">
              <p class="post-card__meta">
                {post.data.publishedAt}
                {post.data.featured ? " · 대표 글" : ""}
              </p>
              <h2 class="post-card__title">
                <a href={`/posts/${post.id}/`}>{post.data.title}</a>
              </h2>
              <p class="post-card__description">{post.data.description}</p>

              {signals.length > 0 && (
                <div class="post-card__signals">
                  {signals.map((signal) => (
                    <span
                      class={
                        signal.accent
                          ? "post-card__signal post-card__signal--accent"
                          : "post-card__signal"
                      }
                    >
                      {signal.label}
                    </span>
                  ))}
                </div>
              )}

              <div class="tag-row">
                {post.data.tags.slice(0, 3).map((tag: string) => (
                  <a href={`/tags/${encodeURIComponent(tag)}/`} class="tag-chip">
                    #{tag}
                  </a>
                ))}
              </div>
            </article>
          );
        })}
      </div>
    </section>
  )}

  <section class="post-list">
    {posts.length > 0 ? (
      posts.map((post) => (
        <article class="post-card">
          <p class="post-card__meta">
            {post.data.publishedAt}
            {post.data.featured ? " · 대표 글" : ""}
          </p>
          <h2 class="post-card__title">
            <a href={`/posts/${post.id}/`}>{post.data.title}</a>
          </h2>
          <p class="post-card__description">{post.data.description}</p>
          <div class="tag-row">
            {post.data.tags.map((tag: string) => (
              <a href={`/tags/${encodeURIComponent(tag)}/`} class="tag-chip">
                #{tag}
              </a>
            ))}
          </div>
        </article>
      ))
    ) : (
      <div class="empty-card">아직 이 카테고리에 등록된 게시물이 없습니다.</div>
    )}
  </section>

  <section class="section-card">
    <div class="section-header">
      <div>
        <p class="eyebrow">다음 탐색</p>
        <h2 class="section-title">이 카테고리와 이어서 볼 경로</h2>
      </div>
    </div>

    <div class="cta-grid">
      <a href="/categories/" class="cta-card">
        <p class="cta-card__label">카테고리</p>
        <h3 class="cta-card__title">전체 카테고리 보기</h3>
        <p class="cta-card__description">
          다른 과학 분야 카테고리로 이동합니다.
        </p>
      </a>

      {featuredTags.map((tag) => (
        <a href={`/tags/${encodeURIComponent(tag)}/`} class="cta-card">
          <p class="cta-card__label">태그</p>
          <h3 class="cta-card__title">#{tag}</h3>
          <p class="cta-card__description">
            이 카테고리에서 자주 등장한 주제어를 이어서 탐색합니다.
          </p>
        </a>
      ))}

      <a href="/search/" class="cta-card">
        <p class="cta-card__label">검색</p>
        <h3 class="cta-card__title">게시물 검색</h3>
        <p class="cta-card__description">
          키워드와 카테고리 필터로 원하는 글을 더 빠르게 찾습니다.
        </p>
      </a>
    </div>
  </section>
</SiteLayout>

<style>
  .section-card {
    padding: 1.5rem;
    border: 1px solid #dde5ed;
    border-radius: 20px;
    background: #ffffff;
    box-shadow: 0 10px 30px rgba(19, 36, 59, 0.06);
  }

  .hero-card {
    background:
      linear-gradient(135deg, rgba(21, 45, 86, 0.04), rgba(24, 110, 128, 0.05)),
      #ffffff;
  }

  .section-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .eyebrow {
    margin: 0 0 0.4rem;
    color: #51719a;
    font-size: 0.9rem;
    font-weight: 700;
  }

  .page-title {
    margin: 0 0 0.6rem;
    font-size: clamp(1.9rem, 3vw, 2.8rem);
    line-height: 1.15;
    letter-spacing: -0.03em;
  }

  .page-description,
  .section-description {
    margin: 0;
    color: #58697a;
  }

  .section-title {
    margin: 0;
    font-size: 1.2rem;
    font-weight: 800;
    letter-spacing: -0.02em;
  }

  .post-list {
    display: grid;
    gap: 1rem;
  }

  .post-card,
  .empty-card {
    padding: 1.4rem;
    border: 1px solid #dde5ed;
    border-radius: 20px;
    background: #ffffff;
    box-shadow: 0 10px 30px rgba(19, 36, 59, 0.06);
  }

  .post-card__meta {
    margin: 0 0 0.45rem;
    color: #51719a;
    font-size: 0.9rem;
    font-weight: 700;
  }

  .post-card__title {
    margin: 0 0 0.65rem;
    font-size: 1.4rem;
    line-height: 1.25;
  }

  .post-card__title a {
    color: inherit;
    text-decoration: none;
  }

  .post-card__description {
    margin: 0;
    color: #58697a;
    line-height: 1.7;
  }

  .post-card__signals {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 0.85rem;
  }

  .post-card__signal {
    display: inline-flex;
    align-items: center;
    padding: 0.42rem 0.72rem;
    border-radius: 999px;
    background: #eef4fb;
    color: #35516e;
    font-size: 0.8rem;
    font-weight: 700;
    line-height: 1;
  }

  .post-card__signal--accent {
    background: #fff1c2;
    color: #7c5a00;
  }

  .tag-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    margin-top: 1rem;
  }

  .tag-chip {
    display: inline-flex;
    align-items: center;
    padding: 0.55rem 0.85rem;
    border-radius: 999px;
    background: #eef5fc;
    color: #244f84;
    font-size: 0.88rem;
    font-weight: 700;
  }

  .cta-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  .cta-card {
    display: block;
    padding: 1rem 1.05rem;
    border: 1px solid #e4ebf2;
    border-radius: 16px;
    background: #fbfdff;
    transition:
      transform 0.2s ease,
      box-shadow 0.2s ease,
      border-color 0.2s ease;
  }

  .cta-card:hover {
    transform: translateY(-2px);
    border-color: #bfd3ea;
    box-shadow: 0 10px 24px rgba(24, 62, 105, 0.08);
  }

  .cta-card__label {
    margin: 0 0 0.35rem;
    color: #51719a;
    font-size: 0.82rem;
    font-weight: 700;
  }

  .cta-card__title {
    margin: 0 0 0.45rem;
    font-size: 1.02rem;
    line-height: 1.35;
  }

  .cta-card__description {
    margin: 0;
    color: #58697a;
    font-size: 0.94rem;
    line-height: 1.65;
  }

  .empty-card {
    color: #58697a;
  }

  @media (max-width: 640px) {
    .section-card,
    .post-card,
    .empty-card {
      padding: 1.1rem;
      border-radius: 16px;
    }

    .section-header {
      flex-direction: column;
      align-items: flex-start;
    }

    .post-card__title {
      font-size: 1.15rem;
    }

    .cta-grid {
      grid-template-columns: 1fr;
    }
  }
</style>