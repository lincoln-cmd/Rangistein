---
import { getCollection } from "astro:content";
import SiteLayout from "../../layouts/SiteLayout.astro";
import { categories, getCategoryBySlug } from "../../data/site";

export async function getStaticPaths() {
  return categories.map((category) => ({
    params: { slug: category.slug },
  }));
}

const { slug } = Astro.params;

if (!slug) {
  throw new Error("Missing category slug.");
}

const category = getCategoryBySlug(slug);

if (!category) {
  throw new Error(`Unknown category slug: ${slug}`);
}

const posts = (await getCollection("posts", ({ data }) => !data.draft))
  .filter((post) => post.data.categorySlug === slug)
  .sort((a, b) => String(b.data.publishedAt).localeCompare(String(a.data.publishedAt)));
---

<SiteLayout
  title={`${category.name} | 랑이슈타인`}
  description={category.description}
  currentPath={`/categories/${category.slug}/`}
>
  <section class="section-card hero-card">
    <p class="eyebrow">Category</p>
    <h1 class="page-title">{category.name}</h1>
    <p class="page-description">{category.description}</p>
  </section>

  <section class="post-list">
    {posts.length > 0 ? (
      posts.map((post) => (
        <article class="post-card">
          <p class="post-card__meta">{post.data.publishedAt}</p>
          <h2 class="post-card__title">
            <a href={`/posts/${post.id}/`}>{post.data.title}</a>
          </h2>
          <p class="post-card__description">{post.data.description}</p>
          <div class="tag-row">
            {post.data.tags.map((tag: string) => (
              <a href={`/tags/${encodeURIComponent(tag)}/`} class="tag-chip">
                #{tag}
              </a>
            ))}
          </div>
        </article>
      ))
    ) : (
      <div class="empty-card">아직 이 카테고리에 등록된 게시물이 없습니다.</div>
    )}
  </section>
</SiteLayout>

<style>
  .section-card {
    padding: 1.5rem;
    border: 1px solid #dde5ed;
    border-radius: 20px;
    background: #ffffff;
    box-shadow: 0 10px 30px rgba(19, 36, 59, 0.06);
  }

  .hero-card {
    background:
      linear-gradient(135deg, rgba(21, 45, 86, 0.04), rgba(24, 110, 128, 0.05)),
      #ffffff;
  }

  .eyebrow {
    margin: 0 0 0.4rem;
    color: #51719a;
    font-size: 0.9rem;
    font-weight: 700;
  }

  .page-title {
    margin: 0 0 0.6rem;
    font-size: clamp(1.9rem, 3vw, 2.8rem);
    line-height: 1.15;
    letter-spacing: -0.03em;
  }

  .page-description {
    margin: 0;
    color: #58697a;
  }

  .post-list {
    display: grid;
    gap: 1rem;
  }

  .post-card,
  .empty-card {
    padding: 1.4rem;
    border: 1px solid #dde5ed;
    border-radius: 20px;
    background: #ffffff;
    box-shadow: 0 10px 30px rgba(19, 36, 59, 0.06);
  }

  .post-card__meta {
    margin: 0 0 0.45rem;
    color: #51719a;
    font-size: 0.9rem;
    font-weight: 700;
  }

  .post-card__title {
    margin: 0 0 0.65rem;
    font-size: 1.4rem;
    line-height: 1.25;
  }

  .post-card__title a {
    color: inherit;
    text-decoration: none;
  }

  .post-card__description {
    margin: 0;
    color: #58697a;
    line-height: 1.7;
  }

  .tag-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    margin-top: 1rem;
  }

  .tag-chip {
    display: inline-flex;
    align-items: center;
    padding: 0.55rem 0.85rem;
    border-radius: 999px;
    background: #eef5fc;
    color: #244f84;
    font-size: 0.88rem;
    font-weight: 700;
  }

  .empty-card {
    color: #58697a;
  }
</style>