---
import BaseLayout from "./BaseLayout.astro";
import Sidebar from "../components/Sidebar.astro";
import { siteDescription, siteTitle } from "../data/site";

export interface Props {
  title?: string;
  description?: string;
  currentPath?: string;
  image?: string;
  noIndex?: boolean;
  ogType?: "website" | "article";
  publishedTime?: string;
  modifiedTime?: string;
  tags?: string[];
  structuredData?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title = siteTitle,
  description = siteDescription,
  currentPath = "/",
  image = "/favicon.png",
  noIndex = false,
  ogType = "website",
  publishedTime,
  modifiedTime,
  tags = [],
  structuredData,
} = Astro.props;
---

<BaseLayout
  title={title}
  description={description}
  image={image}
  noIndex={noIndex}
  ogType={ogType}
  publishedTime={publishedTime}
  modifiedTime={modifiedTime}
  tags={tags}
  structuredData={structuredData}
>
  <main class="page-shell">
    <Sidebar currentPath={currentPath} />

    <div class="content-area">
      <slot />

      <footer class="site-footer">
        <div class="site-footer__top">
          <div>
            <p class="site-footer__eyebrow">Rangistein</p>
            <h2 class="site-footer__title">랑이슈타인</h2>
            <p class="site-footer__description">
              과학 이론, 최신 동향, 논문 요약, 개인 학습 기록을 정리하는 개인 과학 웹 아카이브입니다.
            </p>
          </div>

          <div class="site-footer__nav">
            <a href="/about/" class="site-footer__link">소개</a>
            <a href="/categories/" class="site-footer__link">카테고리</a>
            <a href="/tags/" class="site-footer__link">태그</a>
            <a href="/search/" class="site-footer__link">검색</a>
            <a
              href="https://github.com/lincoln-cmd/Rangistein"
              target="_blank"
              rel="noopener noreferrer"
              class="site-footer__link"
            >
              GitHub
            </a>
            <a href="/admin/index.html" class="site-footer__link">관리자</a>
          </div>
        </div>

        <div class="site-footer__bottom">
          <p class="site-footer__meta">
            문의:
            <a href="mailto:dhkim1551@naver.com">dhkim1551@naver.com</a>
            ·
            <a href="mailto:top12369@gmail.com">top12369@gmail.com</a>
          </p>
          <p class="site-footer__meta">
            <a
              href="https://blog.naver.com/dhkim1551"
              target="_blank"
              rel="noopener noreferrer"
            >
              네이버 블로그
            </a>
          </p>
        </div>
      </footer>
    </div>
  </main>
</BaseLayout>

<style>
  :global(*) {
    box-sizing: border-box;
  }

  :global(html) {
    scroll-behavior: smooth;
  }

  :global(body) {
    margin: 0;
    font-family:
      "Pretendard",
      "Apple SD Gothic Neo",
      "Noto Sans KR",
      Arial,
      sans-serif;
    background: #f4f7fb;
    color: #1d2733;
    line-height: 1.6;
  }

  :global(a) {
    color: inherit;
    text-decoration: none;
  }

  .page-shell {
    display: grid;
    grid-template-columns: 280px minmax(0, 1fr);
    min-height: 100vh;
  }

  .content-area {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    min-width: 0;
    padding: 1.5rem;
  }

  .site-footer {
    margin-top: 0.5rem;
    padding: 1.3rem 1.4rem;
    border: 1px solid #dde5ed;
    border-radius: 20px;
    background: #ffffff;
    box-shadow: 0 10px 30px rgba(19, 36, 59, 0.06);
  }

  .site-footer__top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1.5rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid #e4ebf2;
  }

  .site-footer__eyebrow {
    margin: 0 0 0.3rem;
    color: #51719a;
    font-size: 0.84rem;
    font-weight: 700;
  }

  .site-footer__title {
    margin: 0 0 0.45rem;
    font-size: 1.1rem;
    font-weight: 800;
    letter-spacing: -0.02em;
  }

  .site-footer__description {
    margin: 0;
    max-width: 720px;
    color: #58697a;
    font-size: 0.94rem;
    line-height: 1.7;
  }

  .site-footer__nav {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    justify-content: flex-end;
  }

  .site-footer__link {
    display: inline-flex;
    align-items: center;
    padding: 0.55rem 0.85rem;
    border-radius: 999px;
    background: #eef5fc;
    color: #244f84;
    font-size: 0.88rem;
    font-weight: 700;
    transition:
      transform 0.2s ease,
      box-shadow 0.2s ease,
      background-color 0.2s ease;
  }

  .site-footer__link:hover {
    transform: translateY(-1px);
    box-shadow: 0 8px 18px rgba(24, 62, 105, 0.1);
    background: #e4f0fb;
  }

  .site-footer__bottom {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 0.75rem 1rem;
    padding-top: 1rem;
  }

  .site-footer__meta {
    margin: 0;
    color: #6a7988;
    font-size: 0.9rem;
    line-height: 1.7;
  }

  .site-footer__meta a {
    color: #285ea8;
    font-weight: 700;
  }

  @media (max-width: 1080px) {
    .page-shell {
      grid-template-columns: 240px minmax(0, 1fr);
    }
  }

  @media (max-width: 820px) {
    .page-shell {
      grid-template-columns: 120px minmax(0, 1fr);
    }

    .content-area {
      padding: 1rem;
    }

    .site-footer {
      padding: 1.1rem;
      border-radius: 16px;
    }

    .site-footer__top {
      flex-direction: column;
      align-items: flex-start;
    }

    .site-footer__nav {
      justify-content: flex-start;
    }

    .site-footer__bottom {
      flex-direction: column;
      align-items: flex-start;
    }
  }

  @media (max-width: 520px) {
    .page-shell {
      grid-template-columns: 96px minmax(0, 1fr);
    }
  }
</style>